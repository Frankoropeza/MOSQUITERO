---
// BlogSidebar.astro — Columna lateral del blog. FUENTE ÚNICA de los widgets.
// ============================================================================
// QUÉ RESUELVE: las cuatro vistas del blog (/blog, /blog/[slug], categoría, tag)
// comparten la misma columna derecha. Este componente es esa columna. Duplicarla
// en cada ruta garantiza que en tres meses las cuatro tengan widgets distintos.
//
// EL COMPONENTE HACE SUS PROPIAS CONSULTAS (getCollection), a diferencia de
// BlogCard, que recibe datos planos. La asimetría es deliberada:
//   • BlogCard se dibuja N veces por página → recibe props; que consultara la
//     colección por tarjeta sería absurdo.
//   • BlogSidebar se dibuja UNA vez y sus datos (recientes, conteo por
//     categoría, tags) son los MISMOS en las cuatro rutas. Si los pasara cada
//     página, las cuatro repetirían el mismo bloque de filtrado y ordenado —
//     y bastaría que una se olvidara de excluir drafts para publicar un borrador.
//     Astro resuelve esto en build: cero coste en cliente.
//
// SIN ESTADO DE CLIENTE: no hay JS. El "buscador" es navegación por categoría,
// no un input — un buscador real exige índice y runtime, y el sitio es SSG puro.
//
// WIDGETS (orden = prioridad de intención del lector):
//   1. Categorías (con conteo)  → orientarse
//   2. Artículos recientes       → seguir leyendo
//   3. CTA WhatsApp              → convertir (waUrl, regla D4)
//   4. Temas / tags              → explorar en horizontal
//   5. Cross-sell a catálogo     → puente blog → producto
// ============================================================================

import { getCollection } from 'astro:content';
import { BLOG_CATEGORIES, PRODUCT_CATEGORIES, WA_MESSAGES, waUrl } from '@config/site';
import { navIcon } from '@config/nav-icons';

interface Props {
  /** Slug del artículo actual: se excluye de "recientes" (no te recomiendes a ti mismo). */
  currentSlug?: string;
  /** Slug de la categoría actual: se marca como activa. */
  currentCategory?: string;
  /** Tags del artículo actual: se marcan como activos. */
  currentTags?: string[];
  /** Título del CTA. Default genérico; el artículo pasa uno contextual. */
  ctaHeading?: string;
  /** Mensaje de WhatsApp pre-armado. Default: WA_MESSAGES.blog. */
  waMessage?: string;
}

const {
  currentSlug,
  currentCategory,
  currentTags = [],
  ctaHeading = '¿Te quedó una duda?',
  waMessage = WA_MESSAGES.blog,
} = Astro.props;

// ── Datos: una sola lectura de la colección, filtrada de drafts ──────────────
// El filtro de draft va AQUÍ y en cada ruta. Redundante a propósito: es la
// diferencia entre un borrador visible en un widget y un borrador publicado.
const publicados = (await getCollection('articulos', ({ data }) => data.draft !== true)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

// Recientes: 4 máximo, sin el artículo actual.
const recientes = publicados.filter((p) => p.id !== currentSlug).slice(0, 4);

// Categorías con conteo. Se OCULTAN las vacías: una categoría con (0) es un
// enlace a una página en blanco — ruido para el lector y para el rastreador.
const categorias = BLOG_CATEGORIES.map((c) => ({
  ...c,
  count: publicados.filter((p) => p.data.category === c.slug).length,
})).filter((c) => c.count > 0);

// Tags: aplanados, contados y ordenados por frecuencia. Tope 12 — una nube de
// 40 tags no ayuda a nadie a decidir.
const tagCount = new Map<string, number>();
for (const post of publicados) {
  for (const tag of post.data.tags ?? []) tagCount.set(tag, (tagCount.get(tag) ?? 0) + 1);
}
const tags = [...tagCount.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0], 'es'))
  .slice(0, 12)
  .map(([tag]) => tag);

// Cross-sell: 4 categorías de producto. El puente blog → catálogo.
const catalogo = PRODUCT_CATEGORIES.slice(0, 4);

const waLink = waUrl(waMessage);
const fmtCorta = (d: Date) => d.toLocaleDateString('es-MX', { day: 'numeric', month: 'short' });
---

{/* <aside> + aria-label: el lector de pantalla puede saltarse el bloque entero. */}
<aside class="bsb" aria-label="Barra lateral del blog">
  {/* ── 1) Categorías ── */}
  {categorias.length > 0 && (
    <section class="bsb__w" aria-labelledby="bsb-cats">
      <h2 class="bsb__title" id="bsb-cats">Categorías</h2>
      <ul class="bsb__list" role="list">
        {categorias.map((c) => (
          <li>
            <a
              class:list={['bsb__cat', { 'is-active': c.slug === currentCategory }]}
              href={`/blog/categoria/${c.slug}`}
              aria-current={c.slug === currentCategory ? 'page' : undefined}
            >
              <span class="bsb__cat-label">{c.label}</span>
              <span class="bsb__count">{c.count}</span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {/* ── 2) Recientes ── */}
  {recientes.length > 0 && (
    <section class="bsb__w" aria-labelledby="bsb-recientes">
      <h2 class="bsb__title" id="bsb-recientes">Artículos recientes</h2>
      <ul class="bsb__list bsb__list--posts" role="list">
        {recientes.map((post) => (
          <li>
            <a class="bsb__post" href={`/blog/${post.id}`}>
              <img
                class="bsb__thumb"
                src={post.data.heroImage}
                alt=""
                width="64"
                height="64"
                loading="lazy"
                decoding="async"
              />
              <span class="bsb__post-body">
                <span class="bsb__post-title">{post.data.title}</span>
                <time class="bsb__post-date" datetime={post.data.pubDate.toISOString()}>
                  {fmtCorta(post.data.pubDate)}
                </time>
              </span>
            </a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {/* ── 3) CTA — WhatsApp vía waUrl() (regla D4: nunca un wa.me a mano) ── */}
  <section class="bsb__w bsb__w--cta" aria-labelledby="bsb-cta">
    <h2 class="bsb__title" id="bsb-cta">{ctaHeading}</h2>
    <p class="bsb__cta-desc">
      Mándanos una foto de tu ventana y las medidas. Te decimos qué tipo de mosquitero
      corresponde y te pasamos el precio por pieza.
    </p>
    <a class="bsb__btn" href={waLink} target="_blank" rel="noopener noreferrer">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Escribir por WhatsApp
    </a>
  </section>

  {/* ── 4) Temas / tags ── */}
  {tags.length > 0 && (
    <section class="bsb__w" aria-labelledby="bsb-tags">
      <h2 class="bsb__title" id="bsb-tags">Temas</h2>
      <ul class="bsb__tags" role="list">
        {tags.map((tag) => (
          <li>
            <a
              class:list={['bsb__tag', { 'is-active': currentTags.includes(tag) }]}
              href={`/blog/tag/${tag}`}
            >#{tag}</a>
          </li>
        ))}
      </ul>
    </section>
  )}

  {/* ── 5) Cross-sell al catálogo ── */}
  <section class="bsb__w" aria-labelledby="bsb-catalogo">
    <h2 class="bsb__title" id="bsb-catalogo">Tipos de mosquitero</h2>
    <ul class="bsb__list" role="list">
      {catalogo.map((c) => (
        <li>
          <a class="bsb__link-icon" href={c.href}>
            <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={navIcon(c.icon)} />
            {c.label}
          </a>
        </li>
      ))}
    </ul>
  </section>
</aside>

<style>
  /* CSS vanilla + tokens (C1/C2). El grid de 2 columnas y el sticky los pone la
     PÁGINA/LAYOUT que coloca el aside, no este componente: un componente que se
     posiciona a sí mismo no se puede reutilizar en otra retícula. */
  .bsb { display: grid; gap: var(--sp-5); align-content: start; }

  .bsb__w {
    padding: var(--sp-5);
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
  }

  .bsb__title {
    margin: 0 0 var(--sp-4);
    font-family: var(--font-heading);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    letter-spacing: -0.01em;
    color: var(--c-ink);
    /* Filete corto bajo el título: la misma etiqueta-con-barra del eyebrow de
       SectionHeading, reducida a escala de widget. Homologa el bloque. */
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid var(--c-border);
  }

  .bsb__list { list-style: none; margin: 0; padding: 0; display: grid; gap: var(--sp-1); }

  /* ── Categorías ── */
  .bsb__cat {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    margin-inline: calc(var(--sp-3) * -1);  /* el hover sangra al borde del widget */
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--c-ink-2);
    text-decoration: none;
  }
  .bsb__cat:hover { background: var(--c-surface); color: var(--c-primary); }
  .bsb__cat.is-active { color: var(--c-primary); font-weight: var(--weight-semibold); }
  .bsb__cat.is-active .bsb__count { background: var(--c-primary); color: #fff; }
  .bsb__count {
    flex-shrink: 0;
    min-width: 22px;
    padding: 0 6px;
    border-radius: var(--radius-full);
    background: var(--c-surface);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    line-height: 20px;
    text-align: center;
    color: var(--c-muted);
  }

  /* ── Recientes ── */
  .bsb__list--posts { gap: var(--sp-4); }
  .bsb__post { display: flex; gap: var(--sp-3); text-decoration: none; align-items: flex-start; }
  .bsb__thumb {
    flex-shrink: 0;
    width: 64px; height: 64px;
    object-fit: cover;
    border-radius: var(--radius-md);
    border: 1px solid var(--c-border);
    background: var(--c-surface);
  }
  .bsb__post-body { display: grid; gap: 4px; }
  .bsb__post-title {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-snug);
    color: var(--c-ink);
    /* Recorte a 3 líneas: los títulos miden hasta 70 chars y sin tope el widget
       crece a lo alto y descuadra el sticky. */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .bsb__post:hover .bsb__post-title { color: var(--c-primary); }
  .bsb__post-date { font-size: var(--text-xs); color: var(--c-muted); }

  /* ── CTA ── */
  .bsb__w--cta { background: var(--c-surface); border-color: color-mix(in srgb, var(--c-primary) 22%, var(--c-border)); }
  .bsb__cta-desc { margin: 0 0 var(--sp-4); font-size: var(--text-sm); line-height: var(--leading-normal); color: var(--c-muted); }
  .bsb__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--sp-2);
    width: 100%;
    min-height: 44px;              /* objetivo táctil mínimo (WCAG 2.5.8) */
    padding: var(--sp-3) var(--sp-4);
    border-radius: var(--radius-md);
    background: var(--c-primary);
    color: #fff;
    font-family: var(--font-heading);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    /* ÚNICA transición del componente: es un BOTÓN (excepción del contrato de
       movimiento). Solo color/fondo — nunca transform: el botón no se levanta. */
    transition: background-color var(--transition-btn);
  }
  .bsb__btn:hover { background: var(--c-primary-dark); }

  /* ── Tags ── */
  .bsb__tags { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: var(--sp-2); }
  .bsb__tag {
    display: inline-block;
    padding: 5px var(--sp-3);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    color: var(--c-muted);
    text-decoration: none;
  }
  .bsb__tag:hover { border-color: var(--c-primary); color: var(--c-primary); }
  .bsb__tag.is-active { background: var(--c-primary); border-color: var(--c-primary); color: #fff; }

  /* ── Cross-sell ── */
  .bsb__link-icon {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-3);
    margin-inline: calc(var(--sp-3) * -1);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    color: var(--c-ink-2);
    text-decoration: none;
  }
  .bsb__link-icon svg { flex-shrink: 0; color: var(--c-primary); }
  .bsb__link-icon:hover { background: var(--c-surface); color: var(--c-primary); }

  /* Anillo de foco uniforme para todo lo enfocable del aside. */
  .bsb a:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; border-radius: var(--radius-sm); }
</style>
