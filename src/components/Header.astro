---
// Header.astro — Navegación principal DATA-DRIVEN: mega-menú + dropdowns + drawer móvil.
// ============================================================================
// FUENTE ÚNICA del menú = NAV en @config/site. Este componente NO hardcodea
// NINGÚN ítem: itera NAV para generar (1) el menú de escritorio, (2) los paneles
// desplegables y (3) el drawer móvil. Para editar el menú, edita NAV en site.ts.
//
// DECISIONES DE DISEÑO (y qué problema resuelve cada una):
//
//  1. STICKY DE ALTURA FIJA. El header se pega arriba (top:0) y ya. Hasta el
//     2026-07-14 se compactaba a --header-height-sm al hacer scroll; se quitó
//     con el resto de animaciones. El TopBar NO se pega: scrollea y
//     desaparece. Antes era al revés (TopBar sticky, header relative), así que al
//     bajar quedaba la franja de color sin menú — el CTA de cotizar se perdía.
//
//  2. UN SOLO LENGUAJE EN LOS PANELES. Mega y dropdown pintan la MISMA tarjeta
//     (label + desc) con el mismo markup. La única diferencia es el ancho: el
//     mega ocupa el header completo (catálogo, 7 ítems), el dropdown es una
//     tarjeta angosta (listas cortas). Antes el mega mostraba solo labels y el
//     dropdown label+desc: dos jerarquías en un mismo menú.
//     Sin iconos, a propósito: la jerarquía la llevan el peso tipográfico y la
//     descripción. Sin ellos, la tarjeta se apoya en un borde izquierdo que
//     aparece en hover (ver .nav-card).
//
//  3. ALTURAS Y Z-INDEX DESDE TOKENS, SIN FALLBACKS. Se lee var(--header-height)
//     a secas. Los fallbacks (`var(--header-height, 80px)`) eran el origen del
//     desfase: tokens decía 64px y el CSS 80px, y nadie sabía cuál mandaba.
//
//  4. DRAWER LATERAL. Panel fijo desde la derecha con header propio, acordeones
//     y bloque de contacto. Al ser `inset:0` no depende de la altura del header
//     (el panel anterior se posicionaba con top:calc(topbar+header) y se
//     desalineaba en cuanto la página tenía scroll).
//
// Origen del patrón de interacción: PROYECTORED/src/components/global/Header.astro.
// ============================================================================
import { NAV, SITE, CONTACT, waUrl, telUrl, WA_MESSAGES } from '@config/site'

const currentPath = Astro.url.pathname

// id estable del panel a partir del label (sin acentos). Enlaza el <li data-dropdown>
// con su panel #id — contrato que consume el <script> de interacción más abajo.
const navId = (s: string) =>
  'navp-' + s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-')

// ¿Sección activa? Resalta el ítem de la ruta actual.
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath === href || currentPath.startsWith(href)

const schedule = CONTACT.schedule?.display as string | undefined

const WA_SVG = `<svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`
const PHONE_SVG = `<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>`
const CLOCK_SVG = `<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><polyline points="12 7 12 12 15.5 14"/></svg>`
---

<header class="site-header" id="site-header" role="banner">
  <div class="hdr-inner">

    <a href="/" class="hdr-logo" aria-label={`${SITE.name} — Inicio`}>
      <span class="hdr-logo__mark" aria-hidden="true">{SITE.brand.charAt(0)}</span>
      <span class="hdr-logo__word">{SITE.brand}<span class="hdr-logo__tld">.mx</span></span>
    </a>

    <nav class="hdr-nav" aria-label="Navegación principal">
      <ul class="hdr-nav__list" role="list">
        {NAV.map((item) => !item.panel ? (
          <li class="hdr-nav__item">
            <a href={item.href} class:list={['hdr-nav__link', { 'is-active': isActive(item.href) }]}>{item.label}</a>
          </li>
        ) : (
          <li class="hdr-nav__item" data-dropdown={navId(item.label)}>
            {/* Patrón "disclosure": aria-expanded + aria-controls bastan. NO se
                usa aria-haspopup: equivale a haspopup="menu" y hace que el
                lector prometa un role="menu" navegable con flechas — pero esto
                es un grupo de enlaces, y la promesa incumplida desorienta. */}
            <a
              href={item.href}
              class:list={['hdr-nav__link', { 'is-active': isActive(item.href) }]}
              aria-expanded="false"
              aria-controls={navId(item.label)}
            >
              {item.label}
              <svg class="hdr-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </a>

            {/* DROPDOWN — tarjeta angosta anclada al <li>. Misma tarjeta que el
                mega (icono + label + desc); solo cambia el ancho. */}
            {item.panel === 'dropdown' && (
              <div class="drop-panel" id={navId(item.label)} role="group" aria-label={item.label}>
                <div class="drop-panel__inner">
                  {(item.items ?? []).map((sub) => (
                    <a href={sub.href} class="nav-card">
                      <span class="nav-card__label">{sub.label}</span>
                      {sub.desc && <span class="nav-card__desc">{sub.desc}</span>}
                    </a>
                  ))}
                  <a href={item.href} class="panel-all">
                    {item.allLabel ?? 'Ver todo'}
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                  </a>
                </div>
              </div>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="hdr-actions">
      {/* Llamar: solo <960px. En escritorio el teléfono ya está en el TopBar;
          en móvil el TopBar lo oculta, así que aquí se repone a un toque. */}
      <a href={telUrl()} class="hdr-call" aria-label={`Llamar al ${CONTACT.phone}`}>
        <Fragment set:html={PHONE_SVG} />
      </a>

      <a
        href={waUrl(WA_MESSAGES.cotizar)}
        class="hdr-cta"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Solicitar cotización por WhatsApp"
      >
        <Fragment set:html={WA_SVG} />
        <span>Cotizar</span>
      </a>

      <button class="hdr-burger" id="hdr-burger-btn" aria-label="Abrir menú" aria-expanded="false" aria-controls="hdr-drawer">
        <span class="hdr-burger__box" aria-hidden="true"><span></span><span></span><span></span></span>
      </button>
    </div>
  </div>

  {/* MEGA PANELS — hijos directos del <header> (que es sticky → bloque contenedor
      de sus absolute). Se anclan a top:100% y viajan con el header. */}
  {/* role="navigation": el mega es hermano de .hdr-inner (necesita ser hijo del
      <header> para anclarse a él), así que queda FUERA del <nav> principal. Sin
      este role, las 7 categorías del catálogo —el contenido más navegable del
      sitio— no aparecían al recorrer landmarks con lector de pantalla. */}
  {NAV.filter((item) => item.panel === 'mega').map((item) => (
    <div class="mega-panel" id={navId(item.label)} role="navigation" aria-label={item.label}>
      <div class="mega-panel__inner">
        <div class="mega-panel__head">
          <div class="mega-panel__headings">
            <span class="mega-panel__label">{item.label}</span>
            {item.intro && <p class="mega-panel__intro">{item.intro}</p>}
          </div>
          <a href={item.href} class="panel-all">
            {item.allLabel ?? 'Ver todo'}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
        </div>
        <ul class="mega-grid" role="list">
          {(item.items ?? []).map((sub) => (
            <li>
              <a href={sub.href} class="nav-card">
                <span class="nav-card__label">{sub.label}</span>
                {sub.desc && <span class="nav-card__desc">{sub.desc}</span>}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>
  ))}
</header>

<div class="chrome-overlay" id="hdr-overlay" hidden></div>

{/* DRAWER MÓVIL — generado desde el MISMO NAV. Ítems con panel → acordeón;
    resto → enlace directo. Cierra con Esc, con el velo o con la ✕. */}
{/* role=dialog + aria-modal: se comporta como modal (velo, trampa de foco, Esc,
    bloqueo de scroll), así que debe ANUNCIARSE como modal. Como <aside> a secas
    se leía como contenido complementario. */}
<aside
  class="drawer"
  id="hdr-drawer"
  role="dialog"
  aria-modal="true"
  aria-label="Menú de navegación"
  aria-hidden="true"
  inert
>
  <div class="drawer__head">
    <a href="/" class="hdr-logo" aria-label={`${SITE.name} — Inicio`}>
      <span class="hdr-logo__mark" aria-hidden="true">{SITE.brand.charAt(0)}</span>
      <span class="hdr-logo__word">{SITE.brand}<span class="hdr-logo__tld">.mx</span></span>
    </a>
    <button class="drawer__close" id="hdr-drawer-close" aria-label="Cerrar menú">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true"><line x1="6" y1="6" x2="18" y2="18"/><line x1="18" y1="6" x2="6" y2="18"/></svg>
    </button>
  </div>

  <nav class="drawer__nav" aria-label="Navegación móvil">
    {NAV.map((item) => item.panel ? (
      <div class="mob-item">
        <button class="mob-item__trigger" aria-expanded="false" aria-controls={`mob-${navId(item.label)}`}>
          <span>{item.label}</span>
          <svg class="mob-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
        </button>
        <div class="mob-item__panel" id={`mob-${navId(item.label)}`}>
          <div class="mob-item__panel-inner">
            {(item.items ?? []).map((sub) => (
              <a href={sub.href} class="mob-link">{sub.label}</a>
            ))}
            <a href={item.href} class="mob-link mob-link--all">
              {item.allLabel ?? 'Ver todo'}
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
            </a>
          </div>
        </div>
      </div>
    ) : (
      <a href={item.href} class:list={['mob-direct', { 'is-active': isActive(item.href) }]}>{item.label}</a>
    ))}
  </nav>

  {/* Contacto: cierra el drawer. Quien abre el menú en móvil suele querer
      contactar, no navegar — el CTA no debería obligarlo a buscar. */}
  <div class="drawer__foot">
    <a href={waUrl(WA_MESSAGES.cotizar)} class="drawer__cta" target="_blank" rel="noopener noreferrer">
      <Fragment set:html={WA_SVG} />
      Cotizar por WhatsApp
    </a>
    <a href={telUrl()} class="drawer__phone">
      <Fragment set:html={PHONE_SVG} />
      {CONTACT.phone}
    </a>
    {schedule && (
      <p class="drawer__schedule">
        <Fragment set:html={CLOCK_SVG} />
        {schedule}
      </p>
    )}
  </div>
</aside>

<style>
  /* ══════════════════════════════════════════════════════════════════════════
     HEADER — sticky compacto
     ══════════════════════════════════════════════════════════════════════════ */
  .site-header {
    position: sticky;
    top: 0;
    z-index: var(--z-header);
    background: var(--c-white);
    border-bottom: 1px solid var(--c-border);
    box-shadow: var(--shadow-header);
  }
  /* HISTÓRICO — aquí vivía `.is-scrolled`: al hacer scroll el header pasaba a
     --header-height-sm, encogía el logo y levantaba la sombra, animando la
     altura en --dur-base. Se ELIMINÓ el 2026-07-14 (decisión de Frank: sin
     animaciones). Sin transición, ese cambio de altura era un brinco seco a
     mitad de scroll — y además arrastraba el contenido de abajo 14px, porque
     sticky no saca al header del flujo. Quitarlo se llevó también el sentinel
     + IntersectionObserver del script: menos DOM y menos trabajo en scroll.
     El header ahora es de altura fija, --header-height, siempre. */

  .hdr-inner {
    display: flex;
    align-items: center;
    gap: var(--sp-5);
    height: var(--header-height);
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
  }

  /* ── Logo ─────────────────────────────────────────────────────────────── */
  .hdr-logo {
    display: inline-flex;
    align-items: center;
    gap: .55rem;
    flex-shrink: 0;
    text-decoration: none;
    border-radius: var(--radius-sm);
  }
  .hdr-logo:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 4px; }
  .hdr-logo__mark {
    display: grid;
    place-items: center;
    width: 38px;
    height: 38px;
    border-radius: 11px;
    background: linear-gradient(135deg, var(--c-primary-light), var(--c-primary-dark));
    color: #fff;
    font-family: var(--font-heading);
    font-weight: var(--weight-black);
    font-size: 1.2rem;
    line-height: 1;
    box-shadow: 0 2px 10px rgba(var(--c-primary-rgb), .32);
  }
  .hdr-logo__word {
    font-family: var(--font-heading);
    font-weight: var(--weight-black);
    font-size: 1.3rem;
    letter-spacing: -.02em;
    color: var(--c-ink);
    line-height: 1;
  }
  .hdr-logo__tld { color: var(--c-primary); }

  /* ── Nav escritorio ───────────────────────────────────────────────────── */
  /* El <li> se estira a TODO el alto del header (align-self:stretch). Sin esto
     el <li> medía solo el alto del enlace (~36px) centrado en 72px, así que su
     `top:100%` caía en y≈54 y el dropdown arrancaba DENTRO del header — y el
     solape cambiaba al compactarse (10px → 3px). Estirado, `top:100%` es el
     borde inferior del header, igual que el mega: los dos paneles cuelgan de la
     misma línea y no se mueven al scrollear. */
  .hdr-nav { margin-left: auto; align-self: stretch; }
  .hdr-nav__list { display: flex; align-items: stretch; gap: 2px; list-style: none; margin: 0; padding: 0; height: 100%; }
  .hdr-nav__item { position: relative; display: flex; align-items: center; }
  .hdr-nav__link {
    position: relative;
    display: flex;
    align-items: center;
    gap: .3rem;
    padding: .5rem .75rem;
    font-size: var(--text-sm);
    font-weight: var(--weight-medium);
    color: var(--c-ink-2);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    text-decoration: none;
  }
  .hdr-nav__link:hover { color: var(--c-primary); background: rgba(var(--c-primary-rgb), .07); }
  .hdr-nav__link:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }
  /* Subrayado de sección activa: se dibuja con scaleX para que no dependa de
     paddings escritos a mano (antes: left/right .875rem hardcodeados). */
  .hdr-nav__link.is-active { color: var(--c-primary); font-weight: var(--weight-semibold); }
  .hdr-nav__link.is-active::after {
    content: '';
    position: absolute;
    left: .75rem;
    right: .75rem;
    bottom: .2rem;
    height: 2px;
    border-radius: 2px;
    background: var(--c-primary);
  }
  .hdr-chevron { flex-shrink: 0; opacity: .5; }
  .hdr-nav__item.is-open > .hdr-nav__link { color: var(--c-primary); background: rgba(var(--c-primary-rgb), .07); }
  .hdr-nav__item.is-open .hdr-chevron { transform: rotate(180deg); opacity: 1; }

  /* ══════════════════════════════════════════════════════════════════════════
     TARJETA DE NAVEGACIÓN — el átomo compartido por mega, dropdown y drawer.
     Un solo bloque de estilo = un solo lenguaje visual en todo el menú.
     ══════════════════════════════════════════════════════════════════════════ */
  /* Sin icono, la tarjeta necesitaba otro anclaje: una barra de acento a la
     izquierda que crece en hover (0 → 3px). Ocupa su carril SIEMPRE (el
     padding-left lo reserva), así que al aparecer no empuja el texto. */
  .nav-card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: .1rem;
    min-width: 0;
    padding: .5rem .75rem .5rem .875rem;
    border-radius: var(--radius-sm);
    text-decoration: none;
  }
  .nav-card::before {
    content: '';
    position: absolute;
    left: 0;
    top: .375rem;
    bottom: .375rem;
    width: 3px;
    border-radius: 0 3px 3px 0;
    /* El filete se barría de arriba abajo (scaleX 0→1 + transform-origin:left)
       al hacer hover. Se quitó el `transform`: ahora el filete ocupa su sitio
       siempre y solo CAMBIA DE COLOR — invisible en reposo, primario al pasar el
       ratón. Marca la tarjeta igual, sin un pixel de movimiento.
       (Con `transform: scaleX(0)` en reposo + solo cambio de color en :hover el
       filete se quedaba escalado a 0 y no se veía NUNCA.) */
    background: transparent;
  }
  .nav-card:hover, .nav-card:focus-visible { background: rgba(var(--c-primary-rgb), .06); }
  .nav-card:hover::before, .nav-card:focus-visible::before { background: var(--c-primary); }
  .nav-card:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 1px; }
  .nav-card__label {
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    color: var(--c-ink);
    line-height: var(--leading-snug);
  }
  .nav-card:hover .nav-card__label, .nav-card:focus-visible .nav-card__label { color: var(--c-primary); }
  .nav-card__desc {
    font-size: var(--text-xs);
    color: var(--c-muted);
    line-height: var(--leading-snug);
  }

  /* ── "Ver todo" — mismo botón en mega y dropdown ──────────────────────── */
  .panel-all {
    display: inline-flex;
    align-items: center;
    gap: .375rem;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: .04em;
    text-transform: uppercase;
    color: var(--c-primary);
    text-decoration: none;
    border-radius: var(--radius-sm);
  }
  .panel-all:hover { color: var(--c-primary-dark); }
  .panel-all:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 3px; }
  /* En el dropdown va al pie, separado por una regla. */
  .drop-panel__inner > .panel-all {
    margin-top: .375rem;
    padding: .625rem .75rem .25rem;
    border-top: 1px solid var(--c-border);
    border-radius: 0;
  }

  /* ══════════════════════════════════════════════════════════════════════════
     PANELES — mega (ancho completo) y dropdown (tarjeta angosta)
     Ambos animan igual: fade + 6px de subida, con la curva del chrome.
     ══════════════════════════════════════════════════════════════════════════ */
  /* Cerrado = invisible y fuera del tab order. `visibility` NO es decorativo:
     sin él los ~15 enlaces del panel siguen siendo enfocables con Tab. Antes
     esto hacía fade + 6px de subida; ya no anima (ver CONTRATO DE MOVIMIENTO en
     tokens.css), así que `opacity`/`transform` sobran y el panel aparece y
     desaparece al instante. */
  .mega-panel, .drop-panel {
    pointer-events: none;
    visibility: hidden;
  }
  .mega-panel.is-open, .drop-panel.is-open {
    pointer-events: auto;
    visibility: visible;
  }

  .mega-panel {
    position: absolute;
    left: 0;
    right: 0;
    top: 100%;
    z-index: var(--z-panel);
    background: var(--c-white);
    border-top: 1px solid var(--c-border);
    border-bottom: 1px solid var(--c-border);
    box-shadow: var(--shadow-panel);
    padding-block: var(--sp-5) var(--sp-5);
  }
  .mega-panel__inner {
    max-width: var(--container-max);
    margin-inline: auto;
    padding-inline: var(--container-px);
  }
  .mega-panel__head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: var(--sp-5);
    margin-bottom: var(--sp-4);
    padding-bottom: var(--sp-3);
    border-bottom: 1px solid var(--c-border);
  }
  .mega-panel__headings { min-width: 0; }
  .mega-panel__label {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--c-primary);
    text-transform: uppercase;
    letter-spacing: .1em;
  }
  .mega-panel__intro {
    margin: .3rem 0 0;
    font-size: var(--text-sm);
    color: var(--c-muted);
    line-height: var(--leading-snug);
    max-width: 62ch;
  }
  /* auto-fit: el grid decide cuántas columnas caben. Antes era repeat(4,1fr)
     fijo y a 1024–1200px las tarjetas se estrujaban. */
  .mega-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--sp-2);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .drop-panel {
    position: absolute;
    /* 100% del <li> estirado = borde inferior del header. Misma línea de salida
       que .mega-panel (ver la nota en .hdr-nav). */
    top: 100%;
    left: 0;
    z-index: var(--z-panel);
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-panel);
    width: max-content;
    min-width: 280px;
    max-width: 360px;
  }
  .drop-panel__inner { padding: var(--sp-2); display: flex; flex-direction: column; gap: 2px; }
  /* Los últimos ítems del nav abren hacia la izquierda para no salirse del
     viewport. Lo marca el script con data-align="right". */
  .drop-panel[data-align="right"] { left: auto; right: 0; }

  /* ── Velo ─────────────────────────────────────────────────────────────── */
  .chrome-overlay {
    position: fixed;
    inset: 0;
    z-index: var(--z-overlay);
    background: rgba(20, 24, 31, .38);
    backdrop-filter: blur(2px);
    opacity: 0;
  }
  .chrome-overlay.is-visible { opacity: 1; }
  .chrome-overlay[hidden] { display: none; }
  /* Un solo z-index no sirve para los dos casos del velo:
     · Con un MEGA/DROPDOWN abierto el velo debe quedar DEBAJO del chrome (480 <
       --z-header): el header sigue siendo el elemento activo y el panel cuelga
       de él, así que oscurecerlo sería absurdo.
     · Con el DRAWER abierto el velo es modal y debe tapar TODO. Con 480 quedaba
       debajo del header (500) y del TopBar (500): sobraba una franja encendida
       arriba a la izquierda, con el logo y el CTA "Cotizar" no solo visibles
       sino CLICABLES por encima de un modal. */
  .chrome-overlay.is-over-chrome { z-index: calc(var(--z-header) + 1); }

  /* ══════════════════════════════════════════════════════════════════════════
     ACCIONES (llamar · cotizar · burger)
     ══════════════════════════════════════════════════════════════════════════ */
  .hdr-actions { display: flex; align-items: center; gap: var(--sp-2); flex-shrink: 0; }

  .hdr-cta {
    display: inline-flex;
    align-items: center;
    gap: .45rem;
    padding: .6rem 1.15rem;
    background: var(--c-primary);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-sm);
    white-space: nowrap;
    text-decoration: none;
    box-shadow: 0 2px 10px rgba(var(--c-primary-rgb), .3);
    /* Botón: solo color. Sin transform ni box-shadow — eso era movimiento. */
    transition: background-color var(--transition-btn), color var(--transition-btn);
  }
  .hdr-cta:hover {
    background: var(--c-primary-dark);
    color: #fff;
  }
  .hdr-cta:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 3px; }

  /* Botón de llamar: oculto en escritorio (el TopBar ya lleva el teléfono). */
  .hdr-call {
    display: none;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--c-border);
    color: var(--c-ink-2);
    text-decoration: none;
    transition: color var(--transition-btn), border-color var(--transition-btn), background-color var(--transition-btn);
  }
  .hdr-call:hover { color: var(--c-primary); border-color: var(--c-primary); background: rgba(var(--c-primary-rgb), .06); }
  .hdr-call:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }

  /* Burger: 44×44 (objetivo táctil mínimo). Se cruza a ✕ al abrir. */
  .hdr-burger {
    display: none;
    place-items: center;
    width: 44px;
    height: 44px;
    padding: 0;
    cursor: pointer;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-sm);
    background: none;
    color: var(--c-ink-2);
    transition: border-color var(--transition-btn), color var(--transition-btn);
  }
  .hdr-burger:hover { border-color: var(--c-primary); color: var(--c-primary); }
  .hdr-burger:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }
  .hdr-burger__box { display: grid; gap: 5px; place-items: center; }
  .hdr-burger__box span {
    display: block;
    width: 19px;
    height: 2px;
    border-radius: 2px;
    background: currentColor;
  }
  .hdr-burger[aria-expanded="true"] .hdr-burger__box span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hdr-burger[aria-expanded="true"] .hdr-burger__box span:nth-child(2) { opacity: 0; }
  .hdr-burger[aria-expanded="true"] .hdr-burger__box span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ══════════════════════════════════════════════════════════════════════════
     DRAWER MÓVIL
     inset:0 + translateX → no depende de la altura del header ni del scroll.
     ══════════════════════════════════════════════════════════════════════════ */
  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    z-index: var(--z-panel);
    width: min(380px, 88vw);
    display: flex;
    flex-direction: column;
    background: var(--c-white);
    box-shadow: var(--shadow-panel);
    transform: translateX(100%);
    visibility: hidden;
    overflow-y: auto;
    overscroll-behavior: contain;
    /* Safe-area iOS: el notch/gesture bar no se come el contenido. */
    padding-bottom: env(safe-area-inset-bottom, 0);
  }
  /* Sin slide: el drawer aparece ya puesto. `visibility` sigue sacando sus
     enlaces del tab order mientras está cerrado — eso no es animación. */
  .drawer.is-open { transform: translateX(0); visibility: visible; }

  .drawer__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    padding: var(--sp-4) var(--sp-5);
    border-bottom: 1px solid var(--c-border);
    position: sticky;
    top: 0;
    background: var(--c-white);
    z-index: 1;
  }
  /* 44×44: es el control de cierre principal del modal, no puede quedarse por
     debajo del objetivo táctil mínimo (estaba en 40). */
  .drawer__close {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    cursor: pointer;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-sm);
    background: none;
    color: var(--c-ink-2);
    transition: color var(--transition-btn), border-color var(--transition-btn);
  }
  .drawer__close:hover { color: var(--c-primary); border-color: var(--c-primary); }
  .drawer__close:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }

  .drawer__nav { flex: 1; padding: var(--sp-2) var(--sp-3); }

  .mob-item + .mob-item, .mob-item + .mob-direct, .mob-direct + .mob-item, .mob-direct + .mob-direct {
    border-top: 1px solid var(--c-border);
  }
  .mob-item__trigger {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-3);
    min-height: 52px;
    padding: .875rem var(--sp-3);
    font-family: inherit;
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--c-ink);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    border-radius: var(--radius-sm);
    transition: color var(--transition-btn);
  }
  .mob-item__trigger:hover, .mob-item__trigger[aria-expanded="true"] { color: var(--c-primary); }
  .mob-item__trigger:focus-visible { outline: 2px solid var(--c-primary); outline-offset: -2px; }
  .mob-chevron { flex-shrink: 0; opacity: .5; }
  .mob-item__trigger[aria-expanded="true"] .mob-chevron { transform: rotate(180deg); opacity: 1; }

  /* Acordeón con grid-template-rows 0fr→1fr: anima a altura real sin medir en JS.
     `visibility` NO es decorativo: 0fr + overflow:hidden recorta el panel a la
     vista, pero sus enlaces siguen siendo enfocables y los lee el lector de
     pantalla (aria-expanded="false" anuncia el estado, no oculta nada). Sin
     esto, tabular por el drawer pasaba por ~15 enlaces invisibles. Se retrasa al
     cerrar (delay = duración) para no cortar la animación. */
  .mob-item__panel {
    display: grid;
    grid-template-rows: 0fr;
    visibility: hidden;
  }
  .mob-item__panel.is-open { grid-template-rows: 1fr; visibility: visible; }
  .mob-item__panel > * { min-height: 0; overflow: hidden; }
  .mob-item__panel-inner {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0 var(--sp-2) var(--sp-3) var(--sp-3);
  }

  /* El borde izquierdo hace de guía de sangrado: agrupa visualmente los hijos
     bajo su acordeón, que es el trabajo que hacían los iconos. */
  .mob-link {
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: .5rem .75rem;
    border-left: 2px solid var(--c-border);
    font-size: var(--text-sm);
    color: var(--c-ink-2);
    text-decoration: none;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }
  .mob-link:hover, .mob-link:focus-visible {
    background: rgba(var(--c-primary-rgb), .07);
    color: var(--c-primary);
    border-left-color: var(--c-primary);
    outline: none;
  }
  .mob-link:focus-visible { outline: 2px solid var(--c-primary); outline-offset: -2px; }
  .mob-link--all {
    justify-content: flex-start;
    gap: .375rem;
    margin-top: .25rem;
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: .04em;
    text-transform: uppercase;
    color: var(--c-primary);
  }

  .mob-direct {
    display: flex;
    align-items: center;
    min-height: 52px;
    padding: .875rem var(--sp-3);
    font-size: var(--text-base);
    font-weight: var(--weight-semibold);
    color: var(--c-ink);
    text-decoration: none;
    border-radius: var(--radius-sm);
  }
  .mob-direct:hover { color: var(--c-primary); }
  .mob-direct.is-active { color: var(--c-primary); }
  .mob-direct:focus-visible { outline: 2px solid var(--c-primary); outline-offset: -2px; }

  .drawer__foot {
    display: flex;
    flex-direction: column;
    gap: var(--sp-2);
    padding: var(--sp-4) var(--sp-5) var(--sp-5);
    border-top: 1px solid var(--c-border);
    background: var(--c-surface);
  }
  .drawer__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    min-height: 50px;
    padding: .875rem var(--sp-5);
    background: var(--c-primary);
    color: #fff;
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    border-radius: var(--radius-sm);
    text-decoration: none;
    box-shadow: 0 2px 12px rgba(var(--c-primary-rgb), .32);
    transition: background-color var(--transition-btn);
  }
  .drawer__cta:hover { background: var(--c-primary-dark); color: #fff; }
  .drawer__cta:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 3px; }
  .drawer__phone {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .5rem;
    min-height: 46px;
    padding: .625rem var(--sp-5);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-sm);
    background: var(--c-white);
    color: var(--c-ink);
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    text-decoration: none;
    transition: border-color var(--transition-btn), color var(--transition-btn);
  }
  .drawer__phone:hover { border-color: var(--c-primary); color: var(--c-primary); }
  .drawer__phone:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }
  .drawer__schedule {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: .4rem;
    margin: .125rem 0 0;
    font-size: var(--text-xs);
    color: var(--c-muted);
  }

  /* ══════════════════════════════════════════════════════════════════════════
     RESPONSIVE
     El corte escritorio/móvil es 960px (antes 1024): entre 960 y 1024 el nav
     completo cabe de sobra y mandar esas pantallas a burger era regalar UX.
     ══════════════════════════════════════════════════════════════════════════ */
  @media (max-width: 1180px) {
    .hdr-inner { gap: var(--sp-3); }
    .hdr-nav__link { padding-inline: .5rem; }
    .hdr-nav__link.is-active::after { left: .5rem; right: .5rem; }
    .hdr-cta { padding-inline: .875rem; }
  }

  @media (max-width: 960px) {
    .hdr-nav { display: none; }
    .hdr-actions { margin-left: auto; }
    .hdr-call, .hdr-burger { display: grid; }
    .hdr-cta { padding: .6rem 1rem; }
  }

  @media (max-width: 420px) {
    /* El CTA cede su etiqueta antes que el logo: en el drawer hay uno completo. */
    .hdr-cta span { display: none; }
    .hdr-cta { width: 44px; height: 44px; padding: 0; justify-content: center; }
    .hdr-logo__word { font-size: 1.15rem; }
  }

  @media (max-width: 360px) {
    .hdr-call { display: none; }
  }
</style>

<script>
  // ══════════════════════════════════════════════════════════════════════════
  // Header — estado sticky, paneles (hover + teclado) y drawer móvil.
  // ══════════════════════════════════════════════════════════════════════════
  ;(function () {
    const CLOSE_DELAY = 140 // ms de gracia: deja cruzar el hueco trigger→panel.
    const DESKTOP_BP = 960 // debe coincidir con el @media de arriba.

    // ELIMINADO el 2026-07-14 (sin animaciones): antes de esta línea vivía el
    // "estado sticky" — un sentinel de 1px + IntersectionObserver que ponía
    // `.is-scrolled` para compactar el header al hacer scroll. Sin animación de
    // altura ese compactado era un brinco seco, así que se fue el efecto y con
    // él toda su maquinaria: un nodo menos en el DOM y un observer menos vivo
    // durante todo el scroll. El header es de altura fija.
    // Se fueron con él `const header` y su guarda `if (!header) return`: eran
    // suyos y de nadie más. Lo de abajo usa overlay/drawer/burger con `?.`, así
    // que no necesita guarda de entrada.
    const overlay = document.getElementById('hdr-overlay')
    const drawer = document.getElementById('hdr-drawer')
    const burger = document.getElementById('hdr-burger-btn')
    const drawerClose = document.getElementById('hdr-drawer-close')

    // ── 1. Paneles de escritorio ────────────────────────────────────────────
    type DropItem = {
      trigger: HTMLElement
      link: HTMLElement
      panel: HTMLElement
      timer: ReturnType<typeof setTimeout> | null
    }
    const items: DropItem[] = []
    document.querySelectorAll<HTMLElement>('[data-dropdown]').forEach((trigger) => {
      const panel = document.getElementById(trigger.dataset.dropdown!)
      const link = trigger.querySelector<HTMLElement>('.hdr-nav__link')
      if (!panel || !link) return
      items.push({ trigger, link, panel, timer: null })
    })

    // Dropdown que se saldría por la derecha → se alinea al borde derecho.
    // Se mide una vez al cargar y en resize; los paneles ya están en el DOM.
    function alignDropdowns() {
      items.forEach(({ panel }) => {
        if (!panel.classList.contains('drop-panel')) return
        panel.removeAttribute('data-align')
        const rect = panel.getBoundingClientRect()
        if (rect.right > window.innerWidth - 16) panel.setAttribute('data-align', 'right')
      })
    }

    function clearTimer(item: DropItem) {
      if (item.timer) { clearTimeout(item.timer); item.timer = null }
    }
    function closeItem(item: DropItem) {
      clearTimer(item)
      item.panel.classList.remove('is-open')
      item.trigger.classList.remove('is-open')
      item.link.setAttribute('aria-expanded', 'false')
    }
    function anyOpen() { return items.some((i) => i.panel.classList.contains('is-open')) }

    // Velo — UN solo timer cancelable. La versión anterior encolaba un rAF para
    // añadir .is-visible y un setTimeout para ocultar; al cerrar el drawer desde
    // el propio velo (closeAllPanels() → show=true → rAF; luego closeDrawer() →
    // show=false) el rAF corría DESPUÉS y volvía a marcar .is-visible sobre un
    // velo ya cerrado: se quedaba opaco 240ms y desaparecía de golpe, con la
    // clase pegada. Además el rAF simple nunca daba fade-in: los callbacks de
    // rAF corren ANTES del recálculo de estilo, así que `hidden=false` y
    // `.is-visible` colapsaban en el mismo recálculo y el velo nacía opaco.
    // Aquí se fuerza un reflow explícito, que sí separa los dos estados.
    let overlayTimer: ReturnType<typeof setTimeout> | null = null
    function syncOverlay() {
      if (!overlay) return
      const show = anyOpen() || isDrawerOpen()
      if (overlayTimer) { clearTimeout(overlayTimer); overlayTimer = null }
      // El velo debe tapar el chrome SOLO con el drawer abierto: ver la nota de
      // .is-over-chrome en el CSS.
      overlay.classList.toggle('is-over-chrome', isDrawerOpen())
      if (show) {
        if (overlay.hidden) {
          overlay.hidden = false
          void overlay.offsetHeight // reflow: fija opacity:0 antes del fade
        }
        overlay.classList.add('is-visible')
      } else {
        overlay.classList.remove('is-visible')
        overlayTimer = setTimeout(() => { overlay.hidden = true; overlayTimer = null }, 240)
      }
    }
    function openItem(item: DropItem) {
      if (window.innerWidth <= DESKTOP_BP) return
      clearTimer(item)
      items.forEach((o) => { if (o !== item) closeItem(o) })
      item.panel.classList.add('is-open')
      item.trigger.classList.add('is-open')
      item.link.setAttribute('aria-expanded', 'true')
      syncOverlay()
    }
    function scheduleClose(item: DropItem) {
      clearTimer(item)
      item.timer = setTimeout(() => { closeItem(item); syncOverlay() }, CLOSE_DELAY)
    }
    function closeAllPanels() { items.forEach(closeItem); syncOverlay() }

    items.forEach((item) => {
      item.trigger.addEventListener('mouseenter', () => openItem(item))
      item.trigger.addEventListener('mouseleave', () => scheduleClose(item))
      item.panel.addEventListener('mouseenter', () => clearTimer(item))
      item.panel.addEventListener('mouseleave', () => scheduleClose(item))
      item.link.addEventListener('focus', () => openItem(item))
      item.panel.addEventListener('focusin', () => clearTimer(item))

      const onFocusOut = (e: Event) => {
        const next = (e as FocusEvent).relatedTarget as HTMLElement | null
        if (!next || (!item.trigger.contains(next) && !item.panel.contains(next))) scheduleClose(item)
      }
      item.trigger.addEventListener('focusout', onFocusOut)
      item.panel.addEventListener('focusout', onFocusOut)

      // ↓ / Enter abre el panel y salta al primer enlace (el <a> del trigger
      // sigue navegando a la landing de la sección con Enter si ya está abierto).
      item.link.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') {
          const first = item.panel.querySelector<HTMLElement>('a')
          if (first) { e.preventDefault(); openItem(item); first.focus() }
        }
      })
    })

    document.querySelectorAll('.mega-panel a, .drop-panel a').forEach((a) =>
      a.addEventListener('click', () => setTimeout(closeAllPanels, 50)),
    )

    // ── 2. Drawer móvil ─────────────────────────────────────────────────────
    let lastFocused: HTMLElement | null = null
    let savedScrollY = 0

    function isDrawerOpen() { return !!drawer?.classList.contains('is-open') }

    function openDrawer() {
      if (!drawer || !burger) return
      lastFocused = document.activeElement as HTMLElement
      savedScrollY = window.scrollY
      drawer.classList.add('is-open')
      drawer.setAttribute('aria-hidden', 'false')
      drawer.removeAttribute('inert')
      burger.setAttribute('aria-expanded', 'true')
      burger.setAttribute('aria-label', 'Cerrar menú')
      // Bloqueo de scroll que NO pierde la posición (position:fixed en <body>
      // desplaza al top; se compensa con el offset y se restaura al cerrar).
      // El padding compensa el ANCHO DE LA BARRA DE SCROLL: al sacar el body del
      // flujo, <html> se queda sin contenido scrolleable, la barra desaparece y
      // la página gana ~15px de ancho de golpe (salto lateral visible en
      // Windows/Linux; en macOS con barras superpuestas mide 0 y no se nota).
      const sbw = window.innerWidth - document.documentElement.clientWidth
      document.body.style.position = 'fixed'
      document.body.style.top = `-${savedScrollY}px`
      document.body.style.width = '100%'
      if (sbw > 0) document.body.style.paddingRight = `${sbw}px`
      syncOverlay()
      drawerClose?.focus()
    }

    function closeDrawer() {
      if (!drawer || !burger) return
      drawer.classList.remove('is-open')
      drawer.setAttribute('aria-hidden', 'true')
      drawer.setAttribute('inert', '')
      burger.setAttribute('aria-expanded', 'false')
      burger.setAttribute('aria-label', 'Abrir menú')
      document.body.style.position = ''
      document.body.style.top = ''
      document.body.style.width = ''
      document.body.style.paddingRight = ''
      window.scrollTo(0, savedScrollY)
      syncOverlay()
      lastFocused?.focus()
    }

    burger?.addEventListener('click', () => (isDrawerOpen() ? closeDrawer() : openDrawer()))
    drawerClose?.addEventListener('click', closeDrawer)
    overlay?.addEventListener('click', () => { closeAllPanels(); if (isDrawerOpen()) closeDrawer() })

    // Acordeones del drawer.
    document.querySelectorAll<HTMLElement>('.mob-item__trigger').forEach((btn) => {
      const panel = btn.parentElement?.querySelector<HTMLElement>('.mob-item__panel')
      if (!panel) return
      btn.addEventListener('click', () => {
        const willOpen = btn.getAttribute('aria-expanded') !== 'true'
        // Acordeón exclusivo: abrir uno cierra el resto.
        document.querySelectorAll<HTMLElement>('.mob-item__trigger').forEach((other) => {
          if (other === btn) return
          other.setAttribute('aria-expanded', 'false')
          other.parentElement?.querySelector('.mob-item__panel')?.classList.remove('is-open')
        })
        btn.setAttribute('aria-expanded', String(willOpen))
        panel.classList.toggle('is-open', willOpen)
      })
    })

    drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeDrawer))

    // ── 3. Teclado global ───────────────────────────────────────────────────
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        if (isDrawerOpen()) { closeDrawer(); return }
        const opened = items.find((i) => i.panel.classList.contains('is-open'))
        if (opened) { closeAllPanels(); opened.link.focus() }
        return
      }
      // Trampa de foco: con el drawer abierto, Tab no debe escapar al fondo.
      if (e.key === 'Tab' && isDrawerOpen() && drawer) {
        const focusables = drawer.querySelectorAll<HTMLElement>(
          'a[href], button:not([disabled]), [tabindex]:not([tabindex="-1"])',
        )
        if (!focusables.length) return
        const first = focusables[0]
        const last = focusables[focusables.length - 1]
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus() }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus() }
      }
    })

    // ── 4. Resize ───────────────────────────────────────────────────────────
    let resizeTimer: ReturnType<typeof setTimeout>
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer)
      resizeTimer = setTimeout(() => {
        if (window.innerWidth > DESKTOP_BP && isDrawerOpen()) closeDrawer()
        if (window.innerWidth <= DESKTOP_BP) closeAllPanels()
        alignDropdowns()
      }, 120)
    })

    alignDropdowns()
  })()
</script>
