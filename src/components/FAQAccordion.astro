---
// FAQAccordion.astro — Acordeón de preguntas frecuentes accesible con <details>/<summary>. ORIGEN: MESECI/src/components/FAQ.astro (acordeón nativo, primer item abierto) + FaqCotizacionIndex de PROYECTORED.
// JSON-LD FAQPage: emitSchema=false por defecto. El patrón canónico centraliza el schema en seo.ts (anti-duplicación). Actívalo SÓLO si esta es la única fuente de las FAQs de la página y seo.ts no las emite.
//
// ── DOS MODOS DE LAYOUT ──────────────────────────────────────────────────────
//   1) COLUMNA ÚNICA (default) — acordeón centrado a 820px. Es como lo usan
//      ProductLayout / ServiceLayout / ArticleLayout. Ahí no cambia nada.
//   2) DOS COLUMNAS — se activa SOLO si la página pasa el slot `aside`:
//        preguntas a la izquierda · panel de conversión a la derecha.
//
//      ┌──────────────────────────────┬──────────────────────┐
//      │ <details> ×N                 │ <slot name="aside"/> │ ← sticky ≥1024
//      └──────────────────────────────┴──────────────────────┘
//
//      POR QUÉ UN SLOT Y NO UNA PROP `form={true}`: el acordeón no tiene por qué
//      saber que existe un formulario de cotización. Recibe "algo al lado" y lo
//      coloca; QUÉ sea eso lo decide la página. Así este componente no queda
//      acoplado a QuoteForm ni a config/site.
//
//      POR QUÉ LA FAQ A LA IZQUIERDA: la columna de lectura va donde empieza el
//      ojo; la de acción, a la derecha y pegada, para que siga disponible
//      mientras se recorren las respuestas. Invertirlo pone el formulario antes
//      de haber resuelto la duda que lo bloquea.
// ─────────────────────────────────────────────────────────────────────────────
export interface FAQItem {
  question: string
  answer: string   // admite HTML (set:html)
}
interface Props {
  items: FAQItem[]
  title?: string
  headingId?: string
  /** true → emite <script type="application/ld+json"> FAQPage. Default false (lo hace seo.ts). */
  emitSchema?: boolean
  /** Abrir el primer item por defecto. */
  openFirst?: boolean
  /**
   * true → el componente NO pone padding vertical ni ancho propio: hereda el
   * `.container` de la página. Úsalo cuando el bloque ya vive dentro de una
   * <section class="section"><div class="container">…; si no, se suman dos
   * paddings y el acordeón acaba con un ancho distinto al del resto de la home.
   */
  flush?: boolean
}
const { items = [], title = 'Preguntas frecuentes', headingId = 'faq-heading', emitSchema = false, openFirst = true, flush = false } = Astro.props

// El layout de 2 columnas depende del CONTENIDO, no de una bandera: si la página
// mandó `aside`, hay dos columnas. Una prop `columns` podría contradecir al slot.
const hasAside = Astro.slots.has('aside')

const faqSchema = emitSchema ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: items.map((item) => ({
    '@type': 'Question',
    name: item.question,
    acceptedAnswer: { '@type': 'Answer', text: item.answer.replace(/<[^>]+>/g, '') },
  })),
} : null
---

<section class:list={['faq', flush && 'faq--flush', hasAside && 'faq--split']} aria-labelledby={headingId}>
  <div class="faq__inner">
    {title && <h2 id={headingId} class="faq__title">{title}</h2>}
    <div class="faq__cols">
      <div class="faq__list">
        {items.map((item, idx) => (
          <details class="faq__item" open={openFirst && idx === 0}>
            <summary class="faq__q">
              <span>{item.question}</span>
              <svg class="faq__chevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
            </summary>
            <div class="faq__a"><p set:html={item.answer} /></div>
          </details>
        ))}
      </div>
      {hasAside && (
        <aside class="faq__aside">
          <div class="faq__sticky"><slot name="aside" /></div>
        </aside>
      )}
    </div>
  </div>
  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</section>

<style>
  .faq { padding: var(--section-py, clamp(3rem, 6vw, 5rem)) 0; }
  .faq__inner { max-width: 820px; margin-inline: auto; padding-inline: var(--container-px, 1.5rem); }

  /* flush → el ancho y el padding los pone el .container de la página. */
  .faq--flush { padding: 0; }
  .faq--flush .faq__inner { max-width: none; padding-inline: 0; }

  /* En 2 columnas el bloque necesita el ancho del sitio: a 820px las preguntas
     caerían en una columna de ~450px y el aside no cabría. */
  .faq--split .faq__inner { max-width: var(--container-max, 1200px); }
  .faq--split.faq--flush .faq__inner { max-width: none; }

  .faq__title { font-size: var(--text-3xl, clamp(2rem, 3.5vw, 3rem)); font-weight: var(--weight-bold, 700); margin: 0 0 var(--sp-8, 2rem); text-align: center; color: var(--c-ink, var(--color-gray-900, #111827)); }

  /* Móvil: una sola columna y el aside CAE DEBAJO de las preguntas (orden del
     DOM = orden de lectura, sin `order` que desincronice foco y vista).
     Se vuelve retícula a partir de 1024. */
  .faq__cols { display: grid; gap: var(--sp-6, 2rem); align-items: start; }

  .faq__list { display: flex; flex-direction: column; gap: var(--sp-3, .75rem); }
  .faq__item { border: 1px solid var(--c-border, var(--border, #e8e8e8)); border-radius: var(--radius-lg, .75rem); overflow: hidden; background: var(--c-white, #fff); }
  .faq__q { display: flex; justify-content: space-between; align-items: center; gap: var(--sp-3, .75rem); padding: var(--sp-4, 1rem) var(--sp-5, 1.25rem); cursor: pointer; background: var(--color-gray-50, #fafafa); font-weight: var(--weight-semibold, 600); color: var(--c-ink, var(--color-gray-900, #111827)); list-style: none; }
  .faq__q::-webkit-details-marker { display: none; }
  .faq__q:hover { background: var(--color-gray-100, #f4f4f5); }
  .faq__q:focus-visible { outline: 2px solid var(--c-primary, #C41E24); outline-offset: -2px; }
  .faq__item[open] .faq__q { background: var(--color-red-light, #FEE2E2); }
  /* El chevron conmuta al instante: sigue comunicando abierto/cerrado, sin girar. */
  .faq__chevron { flex-shrink: 0; color: var(--color-red, var(--c-primary, #C41E24)); }
  .faq__item[open] .faq__chevron { transform: rotate(180deg); }
  .faq__a { padding: var(--sp-4, 1rem) var(--sp-5, 1.25rem); color: var(--c-ink-2, var(--color-gray-700, #374151)); line-height: var(--leading-relaxed, 1.7); border-top: 1px solid var(--c-border, var(--border, #e8e8e8)); }
  /* Tope de MEDIDA DE LECTURA, no de diseño. El sitio corre a --container-max:
     90% del viewport: en un monitor de 1792px la columna de preguntas se va a
     ~1040px y la respuesta sale a ~125 caracteres por línea — al saltar de
     renglón el ojo pierde el inicio del siguiente. 68ch la deja en el rango
     legible sin estrechar la barra del <summary>, que es corta y sí debe cruzar
     todo el ancho para que el área de clic sea grande. Mismo criterio que el
     max-width de prosa en SectionHeading. */
  .faq__a :global(p) { margin: 0; max-width: 68ch; text-wrap: pretty; }
  .faq__a :global(a) { color: var(--color-red, var(--c-primary, #C41E24)); }
  /* Los <strong> de las respuestas marcan el dato accionable (la medida, el
     tipo). Sin esto heredan el gris del párrafo y el énfasis se pierde. */
  .faq__a :global(strong) { color: var(--c-ink, #111827); font-weight: var(--weight-semibold, 600); }

  @media (min-width: 1024px) {
    /* 1.35fr / máx. 440px: el formulario no necesita más ancho (sus campos son
       cortos) y las preguntas sí. Un 50/50 deja las respuestas en medida
       apretada y el form estirado y hueco. */
    .faq--split .faq__cols {
      grid-template-columns: minmax(0, 1.35fr) minmax(340px, 440px);
      gap: clamp(2rem, 4vw, 3.5rem);
    }
  }

  /* ── STICKY: SOLO si el panel CABE en la pantalla ─────────────────────────
     La condición de alto NO es un lujo, es un bug arreglado. `position: sticky`
     pega el BORDE SUPERIOR del elemento y ahí lo deja. Si el panel es más alto
     que el viewport, se queda pegado con la parte de abajo fuera de pantalla y
     ya no baja NUNCA: el botón de enviar se vuelve inalcanzable por scroll. Con
     el formulario medido en ~810px + el header pegado, en un portátil de 800px
     de alto eso es exactamente lo que pasaba.
     Por eso el sticky se activa solo cuando hay alto suficiente (≈ panel + header
     + holgura). Por debajo de eso el panel va en flujo normal: se scrollea con
     la página, que es correcto y no rompe nada.
     Si algún día crece el contenido del aside, sube el umbral o quita el sticky
     — nunca lo dejes pegado "a ver si cabe".

     El sticky va en un wrapper INTERNO y no en el <aside>: con `align-items:
     start` la columna no se estira, así que pegar el <aside> no haría nada.
     El `top` descuenta el header pegado; si no, el título del panel queda debajo
     del chrome. */
  @media (min-width: 1024px) and (min-height: 940px) {
    .faq--split .faq__sticky {
      position: sticky;
      top: calc(var(--header-height, 72px) + var(--sp-4, 1rem));
    }
  }

</style>
