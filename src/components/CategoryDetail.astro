---
// CategoryDetail.astro — MÓDULO "A FONDO": bloque de 2 columnas que amplía UNA
// categoría. Origen del patrón: ejemplos.mx/modulos/category-detail.
// ============================================================================
// QUÉ RESUELVE
// La tarjeta de la vitrina (CategoryCard) abre la puerta: imagen, título y dos
// frases. Este bloque la atraviesa: párrafos largos para vender, puntos clave
// para escanear y galería para ilustrar. No duplica la tarjeta — es lo que
// sigue, justo donde la tarjeta ya no alcanza.
//
// REGLA CANÓNICA DEL SITIO (dura): TODOS los bloques van IDÉNTICOS — info a la
// izquierda, galería a la derecha. NO se alternan lados ni fondos. Por eso este
// componente NO expone una prop `reverse`: en el origen existe y está
// documentada como antipatrón, así que aquí directamente no se implementa.
// Coherencia > variedad. Si algún día hace falta, que sea una decisión
// deliberada y no un `reverse` que alguien activó "por dar variedad".
//
// FORMA CANÓNICA: DOS COLUMNAS. Info a la izquierda; a la derecha la galería
// con UNA imagen grande (4:3) y DOS pequeñas debajo, en pareja. La galería no
// ilustra "de adorno": carga la mitad del bloque. La jerarquía es siempre la
// misma —la información pesa, la galería ilustra—, nunca al revés.
//
// La prop `gallery` es técnicamente opcional (sin ella el bloque cae a UNA
// columna con el texto acotado a ancho de lectura) para no reventar si una
// categoría aún no tiene fotos. Pero el uso normal es CON galería: si estás
// escribiendo un bloque nuevo sin ella, para y consigue las tres imágenes.
//
// JERARQUÍA: el título es H2 por defecto (el H1 vive en el Hero). Usa as="h3"
// si el bloque cuelga de una sección que ya tiene su H2.
// ============================================================================

export interface GalleryImage {
  src: string;
  alt: string; // Descriptivo y con keyword. NUNCA "imagen1.jpg".
}

export interface Props {
  /** Ancla opcional (#id) para enlazar el bloque desde el menú de secciones. */
  id?: string;
  /** Etiqueta corta con barra de acento: "La categoría a fondo". */
  eyebrow?: string;
  /** Título del bloque. Obligatorio. */
  title: string;
  /** Cuerpo narrativo: un <p> por string. 2 párrafos es el máximo sano. */
  body?: readonly string[];
  /** Resumen escaneable en 3-5 bullets. NO repitas el body aquí. */
  points?: readonly string[];
  /** Acción única del bloque. Omítela si la categoría aún no tiene página (evita 404). */
  cta?: { label: string; href: string; external?: boolean };
  /** Galería de apoyo. Si se omite → bloque a 1 columna (ver nota de arriba). */
  gallery?: { main: GalleryImage; thumbs?: readonly GalleryImage[] };
  /** Etiqueta del título. h2 por defecto; h3 si cuelga de otro H2. */
  as?: 'h2' | 'h3';
}

const {
  id,
  eyebrow,
  title,
  body = [],
  points = [],
  cta,
  gallery,
  as = 'h2',
} = Astro.props;

// Tag dinámico: mantiene la jerarquía semántica sin duplicar markup.
const Tag = as;
const thumbs = gallery?.thumbs ?? [];
const hasGallery = Boolean(gallery);
---

<div class:list={['cdetail', { 'cdetail--solo': !hasGallery }]} id={id}>
  <div class="cdetail__info">
    {eyebrow && <p class="cdetail__eyebrow">{eyebrow}</p>}
    <Tag class="cdetail__title">{title}</Tag>

    {/* Params anotados explícitamente: es la convención del repo (ver
        SectionHeading.astro) y evita el implicit-any que dispara astro check. */}
    {body.map((p: string) => <p class="cdetail__p">{p}</p>)}

    {points.length > 0 && (
      <ul class="cdetail__points" role="list">
        {points.map((pt: string) => (
          <li class="cdetail__point">
            {/* El check es decoración: el texto ya dice todo. aria-hidden para
                que el lector no anuncie "gráfico" antes de cada punto. */}
            <svg class="cdetail__check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
            <span>{pt}</span>
          </li>
        ))}
      </ul>
    )}

    {cta && (
      <a
        href={cta.href}
        class="cdetail__cta"
        {...(cta.external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
      >
        {cta.label}
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
      </a>
    )}
  </div>

  {gallery && (
    <div class="cdetail__gallery">
      {/* width/height explícitos + aspect-ratio: reservan el hueco antes de que
          la imagen cargue. Sin ellos, cada bloque da un salto de layout (CLS)
          al terminar de descargar. */}
      <figure class="cdetail__figure cdetail__figure--main">
        <img
          src={gallery.main.src}
          alt={gallery.main.alt}
          width="800"
          height="600"
          loading="lazy"
          decoding="async"
        />
      </figure>

      {thumbs.length > 0 && (
        <div class="cdetail__thumbs">
          {thumbs.map((t: GalleryImage) => (
            <figure class="cdetail__figure cdetail__figure--thumb">
              <img src={t.src} alt={t.alt} width="400" height="300" loading="lazy" decoding="async" />
            </figure>
          ))}
        </div>
      )}
    </div>
  )}
</div>

<style>
  /* Móvil primero: una columna. A 768px pasa a dos. */
  .cdetail {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--sp-6);
    /* CENTRADO VERTICAL — decisión de Frank, 2026-07-14.
       Las dos columnas se centran entre sí en escritorio.

       ⚠️ CONTEXTO, PORQUE ESTO ESTUVO EN `start` A PROPÓSITO Y SE DOCUMENTÓ:
       la galería mide más que el texto (imagen 4:3 + fila de thumbs ≈ 660px
       contra ≈ 440px del bloque de texto a 1440px de viewport). Con `center`,
       esa diferencia se reparte arriba y abajo: el eyebrow y el título ya no
       arrancan en el mismo borde que la imagen grande, sino ~110px más abajo.
       El comentario anterior llamaba a eso "el título flotando".

       Frank lo pidió centrado igualmente, y es una decisión de diseño legítima:
       con `start` el bloque quedaba pesado abajo —todo el aire sobrante caía de
       golpe bajo el CTA—. Centrado, el desequilibrio se reparte y el conjunto se
       lee como una unidad. Es un intercambio, no un arreglo: se gana equilibrio
       del bloque y se pierde la línea superior alineada.

       SI ALGÚN DÍA MOLESTA EL HUECO SUPERIOR: la salida NO es volver a `start`
       —eso devuelve el problema de antes—, es igualar las alturas: menos thumbs,
       o mover el CTA al pie de la columna con margin-top:auto. */
    align-items: center;
  }

  @media (min-width: 768px) {
    .cdetail { grid-template-columns: 1fr 1fr; gap: clamp(2rem, 5vw, 4rem); }
    /* Sin galería no hay segunda columna que llenar: el texto se acota a ancho
       de lectura en vez de estirarse a 90% del viewport (líneas de 200
       caracteres son ilegibles). */
    .cdetail--solo { grid-template-columns: minmax(0, var(--container-prose)); }
  }

  .cdetail__info { min-width: 0; }

  /* Eyebrow con barra de acento a la izquierda. */
  .cdetail__eyebrow {
    display: flex;
    align-items: center;
    gap: var(--sp-2);
    margin: 0 0 var(--sp-2);
    font-family: var(--font-heading);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--c-primary);
  }
  .cdetail__eyebrow::before {
    content: '';
    width: 22px;
    height: 2px;
    border-radius: 2px;
    background: var(--c-primary);
    flex-shrink: 0;
  }

  .cdetail__title {
    margin: 0 0 var(--sp-3);
    font-family: var(--font-heading);
    font-size: var(--text-fluid-3xl);
    font-weight: var(--weight-black);
    line-height: var(--leading-tight);
    letter-spacing: -.02em;
    color: var(--c-ink);
  }

  .cdetail__p {
    margin: 0 0 var(--sp-3);
    font-size: var(--text-base);
    line-height: var(--leading-relaxed);
    color: var(--c-ink-2);
    max-width: 62ch;
  }
  .cdetail__p:last-of-type { margin-bottom: var(--sp-4); }

  .cdetail__points {
    list-style: none;
    margin: 0 0 var(--sp-5);
    padding: 0;
    display: grid;
    gap: var(--sp-2);
  }
  .cdetail__point {
    display: flex;
    align-items: flex-start;
    gap: var(--sp-2);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    color: var(--c-ink);
  }
  .cdetail__check {
    flex-shrink: 0;
    margin-top: 1px;
    color: var(--c-primary);
  }

  .cdetail__cta {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-2);
    padding: .7rem 1.4rem;
    background: var(--c-primary);
    color: #fff;
    font-size: var(--text-sm);
    font-weight: var(--weight-semibold);
    border-radius: var(--radius-sm);
    text-decoration: none;
    box-shadow: 0 2px 10px rgba(var(--c-primary-rgb), .3);
    transition: background-color var(--transition-btn);
  }
  .cdetail__cta:hover { background: var(--c-primary-dark); color: #fff; }
  .cdetail__cta:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 3px; }

  /* ── Galería ─────────────────────────────────────────────────────────── */
  .cdetail__gallery { display: grid; gap: var(--sp-3); min-width: 0; }

  .cdetail__figure { margin: 0; overflow: hidden; background: var(--c-surface); }
  .cdetail__figure img { display: block; width: 100%; height: 100%; object-fit: cover; }

  .cdetail__figure--main {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
  }
  .cdetail__figure--thumb {
    aspect-ratio: 4 / 3;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  /* Excepción deliberada a "todo se apila en móvil": los thumbs se quedan en
     pareja SIEMPRE. Dos miniaturas lado a lado se siguen leyendo bien, y
     apilarlas alargaría el bloque sin aportar nada. */
  .cdetail__thumbs { display: grid; grid-template-columns: 1fr 1fr; gap: var(--sp-3); }
</style>
