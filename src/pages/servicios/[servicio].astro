        </ul>
        <p class="otros-l4__all">
          <a href="/servicios">Ver todos los servicios</a> ·
          Trabajamos en {COVERAGE_STATES.map((z, i) => (
            <>
              {i > 0 && (i === COVERAGE_STATES.length - 1 ? " y " : ", ")}
              <a href={zonaHref(z.slug)}>{z.label}</a>
            </>
          ))}
        </p>
      </nav>
    </div>
  </section>

  {/* ═══ FAQ + COTIZACIÓN — el módulo del index ══════════════════════════════
       Las dudas y el formulario van JUNTOS: resolver la duda y no tener dónde
