     ───────────────────────────────────────────────────────────────────────── */

  /* Retícula de "otros tipos": 6 hermanos → 1 → 2 → 3 columnas.
     La base (1fr) y todo lo demás lo pone ficha.css. */
  @media (min-width: 640px) {
    .otros-l4__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .otros-l4__grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
