        </p>
      </nav>

    </div>
  </section>

  {/* ═══ FAQ + COTIZACIÓN — dos columnas, mismo módulo que el index ══════════
       Las dudas y el formulario van JUNTOS a propósito: resolver la duda y no
       tener dónde actuar es perder el lead; poner el formulario antes de
       resolverla es pedirle datos a alguien que todavía no sabe qué pedir.
       Juntos, cada respuesta desemboca en la columna de acción, que en
       escritorio queda pegada mientras se recorre el acordeón.

       Antes de esto (2026-07-14) la FAQ vivía dentro de la columna de contenido
       —estrujada contra la sidebar— y el formulario iba suelto debajo del grid.
       O sea: la duda arriba y la acción 400px más abajo, separadas.

       ESTRUCTURA — copiada del index, una sola <section> y un solo .container:
         SectionHeading  → el H2 del bloque (contrato de 2 columnas del sitio).
         FAQAccordion    → title="" para NO pintar un segundo H2; su
                           aria-labelledby apunta a #faq-heading, que es ese H2.
                           flush → hereda ancho y padding del .container.
         slot="aside"    → QuoteForm. El acordeón no sabe qué es: solo lo coloca.
       El JSON-LD FAQPage lo emite buildSchema() desde `faqs` (schemaData arriba),
       NO este componente — sin `emitSchema` no hay doble FAQPage (anti-patrón B3).

       `id="faq"`: el índice de la sidebar apunta aquí. La sección salió de la
       columna de contenido pero el ancla sigue viva — y el scroll-spy la observa
       igual, porque busca por id en toda la página. ══════════════════════════ */}
  <section class="section section--faq" id="faq">
    <div class="container">
      <SectionHeading
        id="faq-heading"
        eyebrow="Dudas"
        title={`Sobre los ${esAccesorios ? "accesorios" : cat.label.toLowerCase()}`}
        body={[
          esAccesorios
            ? "Lo que más nos preguntan quienes reparan por su cuenta: cómo saber qué refacción es, si vendemos malla por metro y cuándo conviene más el servicio que la pieza suelta."
            : `Lo que más nos preguntan de este tipo en concreto — no de los mosquiteros en general. Si tu duda es cuál te toca o qué malla aguanta tu caso, eso está en el catálogo.`,
          "Si la tuya no está aquí, mándanos tu caso en el formulario: llena lo que sepas, aunque no tengas las medidas todavía. Preferimos resolver la duda antes de fabricar que después de instalar.",
        ]}
      />
      <div class="faq-bloque">
        <FAQAccordion items={[...ficha.faqs]} title="" flush>
          {/* `singular`, no `cat.label`: los labels son plurales y salía "Cotiza
              tu mosquitero enrollables". */}
          <QuoteForm
            slot="aside"
            eyebrow="Cotización"
            title={esAccesorios ? "Pide tu refacción" : `Cotiza tu ${singular}`}
            desc="Déjanos tus datos y te contactamos con el precio por pieza."
          />
        </FAQAccordion>
      </div>
    </div>
  </section>

  <SectionMenu items={menuSecciones} cta={menuCta} ariaLabel="Secciones del sitio" />
</PageLayout>

<script>
  // ══════════════════════════════════════════════════════════════════════════
  // Scroll-spy del índice: marca en qué sección estás.
  // --------------------------------------------------------------------------
  // NO ES UNA ANIMACIÓN — respeta el CONTRATO DE MOVIMIENTO (tokens.css). Solo
  // añade/quita una clase; el cambio de color es instantáneo, sin transición.
  //
  // IntersectionObserver, no un listener de scroll: el listener corre en CADA
  // frame del scroll y es justo el tipo de cosa que hace que una página se
  // sienta pesada. El observer solo dispara cuando una sección cruza el umbral.
  //
  // rootMargin: el header sticky tapa la parte de arriba del viewport, así que
  // la "línea de lectura" real no es y=0 — está bajo el header. El -20%/-70%
  // define una banda estrecha en el tercio superior: la sección activa es la que
  // cruza esa banda, no la que asoma por abajo.
  // ══════════════════════════════════════════════════════════════════════════
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-toc-link]");
  if (links.length > 0) {
    const byId = new Map<string, HTMLAnchorElement>();
    links.forEach((l) => byId.set(l.dataset.tocLink!, l));

    const marcar = (id: string) => {
      links.forEach((l) => l.classList.remove("is-active"));
      byId.get(id)?.classList.add("is-active");
    };

    const obs = new IntersectionObserver(
      (entries) => {
        // Puede haber varias secciones en la banda a la vez (bloques cortos).
        // Se toma la más alta: es la que estás leyendo.
        const visibles = entries
          .filter((e) => e.isIntersecting)
          .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
        if (visibles[0]) marcar(visibles[0].target.id);
      },
      { rootMargin: "-20% 0px -70% 0px", threshold: 0 },
    );

    byId.forEach((_, id) => {
      const sec = document.getElementById(id);
      if (sec) obs.observe(sec);
    });
  }
</script>

