---
// ============================================================================
// mosquiteros/index.astro — MOSQUITEROS · CATÁLOGO (L2). Ruta: /mosquiteros
// ----------------------------------------------------------------------------
// HOMOLOGADA A LA HOME. Mismo ritmo de secciones, mismos componentes, mismas
// reglas. Si cambias el patrón aquí, revisa index.astro — y al revés:
//     1) Hero            → H1 único con la propuesta + kw
//     2) SectionMenu     → barra full-width bajo el hero
//     3) Vitrina         → CategoryCard, uno por tipo (los 7, ver abajo)
//     4) A fondo         → CategoryDetail por tipo (as="h3", cuelga del H2)
//     5) Cómo elegir     → tabla de decisión (lo que esta L2 aporta y la home no)
//     6) FAQ + QuoteForm → dos columnas, misma estructura que la home
//     7) SectionMenu     → menú de guías antes del footer
//
// QUÉ LA DIFERENCIA DE LA HOME, Y POR QUÉ EXISTE
// La home PRESENTA: 4 tipos, blurb corto, empuja a WhatsApp. Esta L2 es el
// CATÁLOGO: los 7 tipos, cada uno a fondo, y —lo que de verdad justifica la
// página— una TABLA DE DECISIÓN que la home no tiene. La intención de búsqueda
// de "qué mosquitero necesito" no se resuelve con una vitrina; se resuelve
// diciendo cuál va con cada ventana. Sin ese bloque, esta página sería la home
// con más tarjetas: contenido duplicado compitiendo consigo mismo.
//
// SEO — keyword-first (regla del portafolio):
//   • kw1 "mosquiteros a medida" abre el title y la description.
//   • Un solo H1 (el Hero). Las secciones abren en H2; los "a fondo" en H3.
//   • FAQ propia de catálogo, DISTINTA de la home: repetir sus 5 preguntas aquí
//     sería el mismo FAQPage dos veces, y Google elige una y descarta la otra.
//     Éstas responden a la intención de catálogo: cuál elijo, qué malla, medidas.
//   • El JSON-LD FAQPage lo emite lib/seo.ts vía schemaData — <FAQAccordion> va
//     SIN `emitSchema` (anti-patrón B3: doble FAQPage).
//   • CollectionPage + ItemList con los 7 tipos, apuntando a sus fichas reales.
//
// ⚠️ ESTADO: 🟢 Frank confirmó (2026-07-14) que se fabrican los 6 tipos y se
// venden accesorios. NO están validados materiales, medidas máximas, mallas en
// stock ni precios — por eso NADA aquí los afirma. Ver docs/GATE-LANZAMIENTO.md.
// ============================================================================
import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/Hero.astro";
import SectionMenu from "@components/SectionMenu.astro";
import SectionHeading from "@components/SectionHeading.astro";
import CategoryCard from "@components/CategoryCard.astro";
import CategoryDetail from "@components/CategoryDetail.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import QuoteForm from "@components/QuoteForm.astro";
import {
  SHOWCASE,
  AFONDO,
  PRODUCT_CATEGORIES,
  COVERAGE_STATES,
  WA_MESSAGES,
  waUrl,
} from "@config/site";

const title = "Mosquiteros a medida | tipos para ventanas y puertas";
const description =
  "Mosquiteros a medida: enrollables, corredizos, abatibles, plisados, magnéticos y fijos. Te decimos cuál va con tu ventana y lo instalamos. Cotiza por WhatsApp.";

// ── Barra bajo el hero ───────────────────────────────────────────────────────
// NO se copia el menú de la home: ésta es la sección Mosquiteros, así que su
// propia entrada sobra. Se enlazan las hermanas. Mismo criterio que la home
// («el hero presenta, la franja convierte»): el último botón es el CTA.
const menuSecciones = [
  { label: "Servicios", href: "/servicios", sub: "Fabricación, instalación y reparación" },
  { label: "Cobertura", href: "/cobertura", sub: "Zonas que atendemos" },
  { label: "Contacto", href: "/contacto", sub: "Teléfono, WhatsApp y correo" },
  { label: "Blog", href: "/blog", sub: "Guías y mantenimiento" },
];
const menuCta = {
  label: "Cotizar por WhatsApp",
  href: waUrl(WA_MESSAGES.productos ?? WA_MESSAGES.cotizar),
  sub: "Mándanos tus medidas",
  external: true,
};

// ── Menú de guías (antes del footer) ─────────────────────────────────────────
// Mismo patrón que la home: enlaza SOLO a artículos que existen. Aquí se eligen
// los de intención de catálogo, no los mismos 4 de la home — un menú idéntico en
// las dos páginas no aporta enlazado nuevo, solo repite.
const menuGuias = [
  { label: "Qué tipo elegir", href: "/blog/tipos-de-mosquitero-cual-elegir", sub: "Cuál va con tu ventana" },
  { label: "Tipos de malla", href: "/blog/tipos-de-malla-mosquitero", sub: "Cuál aguanta tu caso" },
  { label: "Cómo medir", href: "/blog/como-medir-ventana-mosquitero", sub: "Toma bien las medidas del vano" },
  { label: "Reparar o reponer", href: "/blog/reparar-o-reponer-un-mosquitero", sub: "Cuándo conviene cada uno" },
];
const menuGuiasCta = {
  label: "Ver todas las guías",
  href: "/blog",
  sub: "Guías y mantenimiento",
  icon: "arrow" as const,
};

// ── Tabla de decisión — lo que esta L2 aporta y la home no ───────────────────
// 🟠 Conocimiento general del oficio, NO especificaciones del cliente. Dice qué
// tipo va con qué ventana; no dice medidas máximas, materiales ni precios.
// La columna "Piénsalo si…" no es un pero de cortesía: es lo que hace útil la
// tabla. Un catálogo donde todo sirve para todo no ayuda a decidir.
const decision: { tipo: string; slug: string; vaCon: string; piensaloSi: string }[] = [
  {
    tipo: "Enrollable",
    slug: "enrollables",
    vaCon: "Ventana de uso diario donde quieres que la malla desaparezca",
    piensaloSi: "No hay unos centímetros libres arriba del vano para el cajón",
  },
  {
    tipo: "Corredizo",
    slug: "corredizos",
    vaCon: "Ventana o puerta corrediza que ya corre sobre riel",
    piensaloSi: "Tu ventana no es corrediza: no hay riel donde montarlo",
  },
  {
    tipo: "Abatible",
    slug: "abatibles",
    vaCon: "Puerta de acceso por la que entras y sales todo el día",
    piensaloSi: "El espacio no deja abrir una hoja hacia fuera o hacia dentro",
  },
  {
    tipo: "Plisado",
    slug: "plisados",
    vaCon: "Vano amplio o puerta de cristal que otros tipos no cubren",
    piensaloSi: "El vano es pequeño: un corredizo sale más simple y económico",
  },
  {
    tipo: "Magnético",
    slug: "magneticos",
    vaCon: "Puerta por la que pasas con las manos ocupadas",
    piensaloSi: "Es una ventana: está pensado para pasar a través",
  },
  {
    tipo: "Fijo",
    slug: "fijos",
    vaCon: "Ventana de poco uso, cubo de luz, ventana alta",
    piensaloSi: "Necesitas asomarte o limpiar el cristal seguido",
  },
];

// ── FAQ de catálogo ──────────────────────────────────────────────────────────
// DISTINTAS de las de la home a propósito: dos FAQPage con las mismas preguntas
// compiten entre sí y Google descarta una. Éstas responden a la intención de
// quien está eligiendo tipo, no a la de quien acaba de aterrizar.
// 🟠 Sin validar. Cero precios, plazos y garantías (nadie los ha confirmado).
const faqs: { question: string; answer: string }[] = [
  {
    question: "¿Qué tipo de mosquitero necesito para mi ventana?",
    answer:
      "Lo define el marco que ya tienes, no el gusto. Si tu ventana <strong>corre sobre riel</strong>, va un corredizo. Si es una <strong>puerta de acceso diario</strong>, un abatible o un magnético. Si quieres que la malla <strong>desaparezca</strong> cuando no la usas, un enrollable. Si el vano es <strong>amplio o de cristal</strong>, un plisado. Y si la ventana <strong>casi no se abre</strong>, un fijo resuelve por mucho menos. Mándanos una foto de la ventana completa y te decimos cuál es el tuyo.",
  },
  {
    question: "¿Puedo poner un enrollable en cualquier ventana?",
    answer:
      "No siempre. El enrollable necesita <strong>unos centímetros libres arriba del vano</strong> para el cajón donde se recoge la malla. Si ese espacio no existe —porque hay una cortina, un domo o el marco llega al techo— no entra, y forzarlo deja el cajón a la vista o el mosquitero sin cerrar completo. En ese caso te proponemos otro tipo antes de fabricar, no después.",
  },
  {
    question: "¿Qué malla me conviene?",
    answer:
      "Depende del caso, no del tipo de mosquitero: la <strong>misma pieza admite mallas distintas</strong>. Si hay mascotas conviene una malla reforzada que aguante el rasguño; si pega el sol, una que filtre; si el problema son insectos muy chicos, una de trama más cerrada. Cuéntanos qué te pasa en esa ventana y te decimos cuál corresponde. Lo explicamos a fondo en <a href=\"/blog/tipos-de-malla-mosquitero\">tipos de malla</a>.",
  },
  {
    question: "¿Todos se fabrican a la medida?",
    answer:
      "Sí. No trabajamos medidas de línea: cada pieza se arma a las <strong>dimensiones exactas de tu vano</strong>. Es lo que hace que cierre completo, sin huecos por donde se cuele un mosquito. Por eso necesitamos las medidas antes de cotizar — o vamos nosotros a tomarlas.",
  },
  {
    question: "¿Solo se me rompió la malla, tengo que cambiar el mosquitero entero?",
    answer:
      "Casi nunca. Si el <strong>bastidor y los herrajes aguantan</strong>, se cambia solo la tela y queda como nuevo por una fracción de lo que cuesta una pieza nueva. Cuando el marco está vencido o los rodamientos ya no corren, te lo decimos con franqueza — aunque signifique no vender la reparación. También vendemos <a href=\"/mosquiteros/accesorios\">malla y refacciones por separado</a> si reparas por tu cuenta.",
  },
  {
    question: "¿Cuánto cuesta un mosquitero?",
    answer:
      "Depende de tres cosas: las <strong>medidas del vano</strong>, el <strong>tipo</strong> y la <strong>malla</strong>. Por eso cotizamos por pieza y no publicamos una lista de precios que luego no se sostenga. Mándanos las medidas por WhatsApp y te pasamos el precio de tu caso. De qué depende, a fondo, en <a href=\"/blog/de-que-depende-el-precio-de-un-mosquitero\">esta guía</a>.",
  },
];
---

<PageLayout
  title={title}
  description={description}
  pageType="category"
  breadcrumbs={[{ label: "Inicio", href: "/" }, { label: "Mosquiteros" }]}
  schemaData={{
    // CollectionPage + ItemList con los 7 tipos → sus fichas reales (vía
    // productoHref, el interruptor de site.ts). El LocalBusiness sale del grafo
    // base de lib/seo.ts; NO se emite aquí (anti-patrón B3: doble entidad).
    list: {
      name: "Tipos de mosquitero — Mosquitero.mx",
      description,
      path: "/mosquiteros",
      items: PRODUCT_CATEGORIES.map((c) => ({
        name: c.label,
        path: c.href,
        description: c.desc,
      })),
    },
    // El FAQPage lo arma seo.ts desde aquí. <FAQAccordion> va sin `emitSchema`.
    faqs,
  }}
>
  {/* ═══ 1) HERO — H1 único. Las secciones de abajo abren en H2. ═══ */}
  <Hero
    title="Mosquiteros a medida para cada tipo de"
    accent="ventana"
    subtitle="Enrollables, corredizos, abatibles, plisados, magnéticos y fijos. Te decimos cuál va con tu ventana antes de que pidas la pieza equivocada."
    descRight={[
      "El tipo correcto no lo eliges por gusto: lo define el marco que ya tienes y el uso que le das a esa ventana. Un corredizo no entra donde no hay riel, y un enrollable necesita espacio arriba del vano para su cajón. Por eso este catálogo dice, en cada tipo, con qué ventana va — y con cuál no.",
      "Todos se fabrican a la medida exacta de tu vano y los instalamos nosotros. Si tu ventana no encaja claro en ninguno, mándanos una foto por WhatsApp: con verla sabemos cuál corresponde.",
    ]}
  />

  {/* ═══ MENÚ DE SECCIONES — barra full-width bajo el hero ═══ */}
  <SectionMenu items={menuSecciones} cta={menuCta} ariaLabel="Secciones del sitio" />

  {/* ═══ 2) VITRINA — los 7 tipos (la home solo muestra 4: SHOWCASE_HOME) ═══ */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        eyebrow="Catálogo"
        title="Todos los tipos"
        body={[
          "Cada tipo resuelve un problema distinto. Abajo está el catálogo completo con lo que hace cada uno: el enrollable esconde la malla, el corredizo aprovecha el riel que ya tienes, el abatible aguanta el paso diario, el plisado cubre lo que los demás no alcanzan.",
          "Si vienes de la home, aquí están los siete —incluidos magnéticos, fijos y las refacciones sueltas—. Entra a cualquiera para ver cómo funciona y en qué ventana encaja.",
        ]}
      />
      <div class="showcase">
        {SHOWCASE.map((cat, i) => (
          <CategoryCard
            label={cat.label}
            href={cat.href}
            image={cat.image}
            imageAlt={cat.imageAlt}
            badge={cat.badge}
            blurb={cat.blurb}
            subcategories={cat.subcategories}
            ctaLabel={cat.ctaLabel}
            index={i}
          />
        ))}
      </div>
    </div>
  </section>

  {/* ═══ 3) CÓMO ELEGIR — el bloque que justifica esta L2 ═══════════════════
      Sin esto, la página sería la home con más tarjetas: mismo contenido
      compitiendo consigo mismo por la misma búsqueda. La intención de "qué
      mosquitero necesito" se resuelve aquí, no en una vitrina.
      La columna "Piénsalo si…" es la que da confianza: un catálogo donde todo
      sirve para todo no ayuda a nadie a decidir. ══════════════════════════ */}
  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Cómo elegir"
        title="Cuál va con tu ventana"
        body={[
          "Esta es la tabla que usamos nosotros cuando nos mandas una foto. Busca tu caso en la columna del medio: casi siempre hay un solo tipo que encaja, y los demás quedan descartados por el marco que ya tienes.",
          "La última columna es igual de importante. Decimos cuándo un tipo NO conviene porque preferimos que no compres la pieza equivocada — devolver un mosquitero a medida no es una opción para nadie.",
        ]}
      />

      <div class="tabla-wrap">
        <table class="tabla">
          <caption class="tabla__caption">
            Qué tipo de mosquitero corresponde a cada ventana
          </caption>
          <thead>
            <tr>
              <th scope="col">Tipo</th>
              <th scope="col">Va con…</th>
              <th scope="col">Piénsalo si…</th>
            </tr>
          </thead>
          <tbody>
            {decision.map((d) => (
              <tr>
                <th scope="row" class="tabla__tipo">
                  <a href={`/mosquiteros/${d.slug}`}>{d.tipo}</a>
                </th>
                <td>{d.vaCon}</td>
                <td class="tabla__pero">{d.piensaloSi}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>

      <p class="tabla__nota">
        ¿Sigues sin verlo claro? Es lo más normal — casi nadie llega sabiendo si
        su ventana pide un corredizo o un enrollable. Mándanos una foto de la
        ventana completa y te lo decimos nosotros.
      </p>
    </div>
  </section>

  {/* ═══ 4) CADA TIPO, A FONDO ══════════════════════════════════════════════
      Mismo patrón que la home: se recorre SHOWCASE y se filtra por AFONDO[slug],
      así una categoría sin entrada en AFONDO no rompe la sección.
      as="h3" NO es opcional: estos bloques cuelgan del H2 de esta sección. Con
      el h2 por defecto del componente saldrían siete H2 bajo otro H2 — un salto
      de jerarquía hacia arriba. Regla: H2 sección padre → H3 sub-bloque.
      ═══════════════════════════════════════════════════════════════════════ */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        eyebrow="A fondo"
        title="Cómo funciona cada uno"
        body={[
          "Aquí se amplía lo de arriba sin obligarte a entrar a otra página: cómo trabaja cada mecanismo, qué caso resuelve y qué condición pide del vano.",
          "Si prefieres el detalle completo de un tipo —con su galería y sus puntos— entra a su ficha desde el botón de cada bloque.",
        ]}
      />
      <div class="afondo">
        {SHOWCASE.filter((cat) => AFONDO[cat.slug]).map((cat) => (
          <CategoryDetail
            id={`afondo-${cat.slug}`}
            as="h3"
            eyebrow="El tipo a fondo"
            title={cat.label}
            body={AFONDO[cat.slug].body}
            points={AFONDO[cat.slug].points}
            gallery={AFONDO[cat.slug].gallery}
            cta={{ label: cat.ctaLabel ?? `Ver ${cat.label}`, href: cat.href }}
          />
        ))}
      </div>
    </div>
  </section>

  {/* ═══ 5) FAQ + COTIZACIÓN — misma estructura que la home ══════════════════
      Una sola <section>, un solo <div class="container">: el SectionHeading pone
      el H2 y <FAQAccordion title="" flush> hereda el contenedor en vez de crear
      el suyo. `flush` evita que se sumen dos paddings y el acordeón acabe con un
      ancho distinto al del resto de la página.
      El JSON-LD FAQPage lo emite lib/seo.ts vía schemaData — por eso el acordeón
      va SIN `emitSchema` (anti-patrón B3: doble FAQPage). ═══════════════════ */}
  <section class="section section--faq">
    <div class="container">
      <SectionHeading
        id="faq-heading"
        eyebrow="Dudas"
        title="Antes de elegir tu mosquitero"
        body={[
          "Estas son las preguntas que más nos llegan de quien está decidiendo qué tipo pedir: cuál corresponde, qué malla aguanta su caso y de qué depende el precio.",
          "Si la tuya no está aquí, escríbenos. Preferimos resolverla antes de fabricar que después de instalar.",
        ]}
      />
      <div class="faq-bloque">
        <FAQAccordion items={faqs} title="" flush>
          <QuoteForm slot="aside" />
        </FAQAccordion>
      </div>
    </div>
  </section>

  {/* ═══ 6) MENÚ DE GUÍAS — barra full-width antes del footer ═══ */}
  <SectionMenu items={menuGuias} cta={menuGuiasCta} ariaLabel="Guías para elegir tu mosquitero" />
</PageLayout>

<style>

  /* ── Vitrina — homologada con la home, pero 4 por fila deja 7 en 2 filas
     (4 + 3). Con `auto-fit` la última fila estiraría 3 tarjetas a lo ancho y se
     verían distintas a las de arriba. Columnas fijas: el hueco de la última fila
     es preferible a tarjetas de dos tamaños. ── */
  .showcase { display: grid; grid-template-columns: 1fr; gap: var(--sp-5); }
  @media (min-width: 640px) { .showcase { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .showcase { grid-template-columns: repeat(4, 1fr); } }

  /* ── Tabla de decisión ──
     Con scroll horizontal en móvil en vez de apilar: una tabla de comparación
     apilada deja de ser una comparación — el valor está en leer las columnas
     enfrentadas. El wrapper es focusable (tabindex en el markup del navegador
     no; aquí se resuelve con overflow + role) para que se pueda desplazar con
     teclado. */
  .tabla-wrap {
    margin-top: var(--sp-6);
    overflow-x: auto;
    border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
    background: var(--c-white);
  }
  .tabla { width: 100%; border-collapse: collapse; min-width: 640px; }
  .tabla__caption {
    padding: var(--sp-4) var(--sp-5) 0;
    font-size: var(--text-sm); color: var(--c-muted); text-align: left;
  }
  .tabla th, .tabla td {
    padding: var(--sp-4) var(--sp-5);
    text-align: left; vertical-align: top;
    font-size: var(--text-sm); line-height: var(--leading-normal);
    border-bottom: 1px solid var(--c-border);
  }
  .tabla thead th {
    font-family: var(--font-heading);
    font-size: var(--text-xs); font-weight: var(--weight-bold);
    letter-spacing: .04em; text-transform: uppercase;
    color: var(--c-muted); background: var(--c-surface);
    border-bottom: 1px solid var(--c-border);
  }
  .tabla tbody tr:last-child th, .tabla tbody tr:last-child td { border-bottom: 0; }
  .tabla__tipo {
    font-family: var(--font-heading); font-weight: var(--weight-semibold);
    color: var(--c-ink); white-space: nowrap;
  }
  .tabla__tipo a { color: var(--c-primary); text-decoration: none; }
  .tabla__tipo a:hover { text-decoration: underline; }
  .tabla__tipo a:focus-visible { outline: 2px solid var(--c-primary); outline-offset: 2px; }
  .tabla td { color: var(--c-ink-2); }
  .tabla__pero { color: var(--c-muted); }
  .tabla__nota {
    margin: var(--sp-4) 0 0; font-size: var(--text-sm);
    color: var(--c-muted); line-height: var(--leading-normal); max-width: 66ch;
  }

  /* ── Pila de bloques "a fondo" — mismo gap generoso que la home: cada bloque
     es una unidad de lectura completa y necesita respirar para no leerse como
     una lista. ── */
  .afondo { display: grid; gap: clamp(2.5rem, 6vw, 5rem); margin-top: var(--sp-8); }

  /* ── FAQ + formulario ── */
  .faq-bloque { margin-top: var(--sp-6); }

  @media (min-width: 768px) {
    .section { padding: var(--sp-10) 0; }
  }
</style>
