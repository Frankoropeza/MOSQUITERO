<style>


  /* ── Vitrina de categorías — 4 por fila en escritorio (2 tablet, 1 móvil) ── */
  .showcase { display: grid; grid-template-columns: 1fr; gap: var(--sp-5); }
  @media (min-width: 640px) { .showcase { grid-template-columns: repeat(2, 1fr); } }
  @media (min-width: 1024px) { .showcase { grid-template-columns: repeat(4, 1fr); } }

  /* Pila de bloques "a fondo". El gap es GRANDE y uniforme a propósito: cada
     bloque es una unidad de lectura completa y necesita respirar para no leerse
     como una lista. Regla canónica: gap parejo, sin alternar lados ni fondos.
     El separador superior marca el corte entre "catálogo de un vistazo"
     (tarjetas) y "cada tipo explicado" (estos bloques).

     SIN max-width: estos bloques ocupan el MISMO ancho que la vitrina de
     tarjetas y que el resto de la home (el .container, --container-max: 90%).
     Lo probé capado a 1140px para equilibrar la altura de las columnas y era
     peor: metía un ancho distinto al del resto de la página. La coherencia de
     ancho manda; el equilibrio vertical se resuelve dentro del bloque, no
     estrechándolo (ver la nota de .cdetail__gallery en CategoryDetail.astro). */
  .afondo {
    display: grid;
    gap: clamp(2.5rem, 6vw, 5rem);
    margin-top: var(--sp-8);
    padding-top: var(--sp-8);
    border-top: 1px solid var(--c-border);
  }
  /* Con 4+ bloques apilados, el clamp de escritorio se siente excesivo en
     pantallas chicas: comprime sin llegar a sentirse apretado. */
  @media (max-width: 480px) {
    .afondo { gap: var(--sp-6); margin-top: var(--sp-6); padding-top: var(--sp-6); }
  }

  /* ── Servicios ────────────────────────────────────────────────────────────
     CONCEPTO: la tarjeta ES un mosquitero. No hay ícono, imagen ni movimiento:
     la carga visual la lleva la construcción de la pieza.
       • marco exterior + hairline interior = el PERFIL de aluminio con su junta.
       • trama CSS a 5px = la TELA tensada dentro del marco.
       • esquina superior izquierda = la ESCUADRA de ensamble del perfil.
     Es la única sección de la home sin foto; la textura evita que se lea como un
     hueco, y sale del producto — no es decoración prestada de otra plantilla.

     POR QUÉ SIN HOVER: estas tarjetas NO son enlaces (/servicios/{id}/ aún no
     existe). Un lift o un cambio de color prometería un clic que no hay. */
  .servicios { display: grid; grid-template-columns: 1fr; gap: var(--sp-4); }

  /* El marco: fondo blanco = cara del perfil de aluminio. */
  .servicio {
    position: relative;
    /* Top a --sp-6 (32px): deja respirar la escuadra, que llega hasta los 26px
       (inset 8 + 18 de trazo). Con --sp-5 el título se le montaba. */
    padding: var(--sp-6) var(--sp-5) var(--sp-5);
    background: var(--c-white);
    border: 1px solid var(--c-border);
    border-radius: var(--radius-sm);
  }

  /* El panel de tela: hairline de junta + trama. La malla real es cuadrícula
     fina, no un patrón diagonal: dos repeating-linear-gradient a 5px de paso
     con alfa muy baja (.045) — se lee como textura de papel, no como reja, y no
     estorba al texto que va encima (z-index). */
  .servicio::before {
    content: "";
    position: absolute; inset: var(--sp-2); z-index: 0;
    border: 1px solid var(--c-border);
    background-image:
      repeating-linear-gradient(0deg,  rgba(20, 24, 31, .045) 0 1px, transparent 1px 5px),
      repeating-linear-gradient(90deg, rgba(20, 24, 31, .045) 0 1px, transparent 1px 5px);
    pointer-events: none;
  }

  /* La escuadra: dos trazos en ángulo, en primario, sobre la junta superior
     izquierda. Es el único punto de color de la tarjeta — marca el inicio de
     lectura sin robarle peso al título. */
  .servicio::after {
    content: "";
    position: absolute; z-index: 1;
    top: var(--sp-2); left: var(--sp-2);
    width: 18px; height: 18px;
    border-top: 2px solid var(--c-primary);
    border-left: 2px solid var(--c-primary);
    pointer-events: none;
  }

  .servicio__contenido { position: relative; z-index: 1; }

  /* El título sube a --text-lg y a font-heading: sin ícono, la jerarquía la
     tiene que llevar la tipografía sola. */
  .servicio__titulo {
    margin: 0 0 var(--sp-3);
    font-family: var(--font-heading); font-size: var(--text-lg);
    font-weight: var(--weight-semibold); line-height: var(--leading-tight);
    color: var(--c-ink); text-wrap: balance;
  }
  /* Filete corto bajo el título: separa sin meter una línea de borde completa. */
  .servicio__titulo::after {
    content: ""; display: block;
    width: 28px; height: 2px; margin-top: var(--sp-3);
    background: var(--c-primary);
  }
  .servicio__desc {
    margin: 0; font-size: var(--text-sm); color: var(--c-ink-2);
    line-height: var(--leading-normal); text-wrap: pretty;
  }

  /* La trama es decorativa: en alto contraste desaparece antes que el texto. */
  @media (prefers-contrast: more) {
    .servicio::before { background-image: none; }
  }

  /* ── Proceso ──
     MISMA tarjeta que .servicio (borde, radio, filete de acento en hover, alza
     de 3px) + media 4:3 arriba. Se mantiene <ol>/<li>: el orden de los pasos es
     semántico, no decorativo — el número visible es el badge sobre la foto y va
     aria-hidden porque la lista ya lo comunica. */
  .pasos { list-style: none; margin: 0; padding: 0; display: grid; grid-template-columns: 1fr; gap: var(--sp-4); }
  /* CONTRATO DE MOVIMIENTO (tokens.css): la tarjeta NO anima y NO reacciona al
     hover. Antes se levantaba 3px, crecía la foto y le barría un filete de color
     por arriba. Todo eso se quitó de raíz — no basta con borrar la `transition`:
     dejar el `:hover { transform }` sin transición hace que la tarjeta PEGUE UN
     SALTO instantáneo, que se siente peor que la animación. Se quita el efecto,
     no su duración. El filete superior se queda fijo: era el único elemento con
     valor informativo del conjunto (marca el inicio de la tarjeta). */
  .paso {
    position: relative; isolation: isolate; overflow: hidden;
    display: flex; flex-direction: column;
    background: var(--c-white); border: 1px solid var(--c-border);
    border-radius: var(--radius-lg);
  }
  .paso::before {
    content: ""; position: absolute; inset: 0 0 auto 0; height: 3px; z-index: 2;
    background: linear-gradient(90deg, var(--c-primary), var(--c-primary-light));
  }

  .paso__media { position: relative; aspect-ratio: 4 / 3; overflow: hidden; background: var(--c-surface); }
  .paso__img { width: 100%; height: 100%; object-fit: cover; display: block; }
  /* Velo inferior: asienta el badge cuando llegue la foto real (contraste). */
  .paso__velo { position: absolute; inset: 0; background: linear-gradient(180deg, transparent 60%, rgba(0,0,0,.16) 100%); }

  .paso__num {
    position: absolute; top: var(--sp-3); left: var(--sp-3);
    display: grid; place-items: center; width: 34px; height: 34px;
    border-radius: var(--radius-full); background: var(--c-primary); color: #fff;
    font-family: var(--font-heading); font-size: var(--text-sm); font-weight: var(--weight-bold);
    box-shadow: 0 2px 8px rgba(0,0,0,.18);
  }

  .paso__body { display: flex; flex-direction: column; gap: var(--sp-2); flex-grow: 1; padding: var(--sp-5); }
  .paso__titulo {
    margin: 0; font-family: var(--font-heading); font-size: var(--text-base);
    font-weight: var(--weight-semibold); line-height: var(--leading-snug); color: var(--c-ink);
  }
  .paso__detalle { margin: 0; font-size: var(--text-sm); color: var(--c-ink-2); line-height: var(--leading-normal); }

  /* ── FAQ + cotización ─────────────────────────────────────────────────────
     El separador NO es decoración: marca que el bloque cambia de registro —de
     "te explicamos" a "ahora te toca a ti"— y le da al formulario un borde
     superior contra el cual apoyarse. Mismo recurso que .afondo, a propósito:
     una sola forma de anunciar un corte dentro de una sección. */
  .faq-bloque {
    margin-top: var(--sp-8);
    padding-top: var(--sp-8);
    border-top: 1px solid var(--c-border);
  }
  @media (max-width: 480px) {
    .faq-bloque { margin-top: var(--sp-6); padding-top: var(--sp-6); }
  }

  /* Aquí vivía un bloque `prefers-reduced-motion` que apagaba las transiciones de
     .paso. Se fue con ellas: ya no hay nada que apagar. El único bloque de
     movimiento reducido del sitio es el global de tokens.css. */

  /* ── Desktop ── */
  @media (min-width: 768px) {
    .section { padding: var(--sp-10) 0; }
    .servicios { grid-template-columns: repeat(2, 1fr); }
    .pasos { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 1024px) {
    .servicios { grid-template-columns: repeat(4, 1fr); }
    /* 8 pasos = dos filas limpias de 4, misma retícula que .servicios. Se fue el
       truco de span/centrado que hacía falta con 5: con múltiplo de 4 no hay
       fila huérfana. Si el cliente confirma otro número de pasos (ver el TODO
       de `proceso` en el frontmatter), esto no se rompe — solo deja hueco en la
       última fila. */
    .pasos { grid-template-columns: repeat(4, 1fr); }
  }
</style>
