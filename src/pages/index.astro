---
// ============================================================================
// index.astro — HOME de mosquitero.mx (L1).
// ----------------------------------------------------------------------------
// ESTADO: ya NO es la única página. El 2026-07-14 se construyeron /mosquiteros
// (+7 fichas), /servicios (+4 fichas), /cobertura (+2 zonas) y /contacto: 46
// páginas. Los enlaces del NAV ya resuelven — verificado con `npm run check:links`.
// La L2 de catálogo es /mosquiteros, NO /productos: la URL dice lo mismo que el
// botón que lleva a ella (renombrada por Frank).
//
// REGLAS:
//   • Cero datos de negocio hardcodeados: todo sale de src/config/site.ts.
//   • WhatsApp SIEMPRE vía waUrl() (regla D4), nunca un wa.me a mano.
//   • Las metas se generan de KEYWORDS con la regla keyword-first (lib/seo.ts).
//   • ⚠️ Los textos marcados TODO son placeholders: valídalos con el cliente
//     antes de publicar. Cero contenido fabricado (sin cifras ni promesas
//     que el negocio no pueda sostener).
// ============================================================================
import PageLayout from "@layouts/PageLayout.astro";
import Hero from "@components/Hero.astro";
import SectionMenu from "@components/SectionMenu.astro";
import SectionHeading from "@components/SectionHeading.astro";
import CategoryCard from "@components/CategoryCard.astro";
import CategoryDetail from "@components/CategoryDetail.astro";
import FAQAccordion from "@components/FAQAccordion.astro";
import QuoteForm from "@components/QuoteForm.astro";
import { getCollection } from "astro:content";
// SHOWCASE_HOME, no SHOWCASE: la home presenta 4 tipos; el catálogo completo (7)
// es la L2 /mosquiteros. El corte vive en site.ts para que meter una categoría
// nueva no alargue la home sin que nadie lo decida. Ver SHOWCASE_HOME.
import { KEYWORDS, NAV, SERVICES, WA_MESSAGES, SHOWCASE_HOME, AFONDO, waUrl } from "@config/site";

// Se fueron con el CTA final (2026-07-14): el import de CTABanner y el
// `const waLink = waUrl()`, que era su único consumidor en esta página. El
// componente sigue vivo y en uso en los layouts y en /blog — solo la home dejó
// de llamarlo. `waUrl` se queda: lo usa menuCta más abajo.

// ── Menú de secciones (barra bajo el hero) ───────────────────────────────────
// DATA-DRIVEN desde NAV (site.ts) — la MISMA fuente que alimenta el Header. Se
// excluye "Contacto" porque su intención la cubre el CTA. El último botón NO sale
// de NAV: es el CTA de conversión por WhatsApp (regla «el hero presenta, la
// franja convierte»).
const menuSub: Record<string, string> = {
  Mosquiteros: "Tipos y catálogo",
  Servicios: "Fabricación, instalación y reparación",
  Cobertura: "Zonas que atendemos",
  Blog: "Guías y mantenimiento",
};
const menuSecciones = NAV.filter((n) => n.label !== "Contacto").map((n) => ({
  label: n.label,
  href: n.href,
  sub: menuSub[n.label] ?? n.items?.slice(0, 3).map((i) => i.label).join(" · ") ?? "Ver sección",
}));
const menuCta = {
  label: "Cotizar por WhatsApp",
  href: waUrl(WA_MESSAGES.cotizar),
  sub: "Mándanos tus medidas",
  external: true,
};

// ── Menú de guías (segunda barra, antes del footer) ──────────────────────────
// Objetivo: enlazado interno. Enlaza SOLO a artículos del blog que existen
// —con guarda que rompe el build si un slug deja de generar ruta—. Cuando se
// escribió, la barra del hero apuntaba a rutas inexistentes; ya no es el caso.
//
// ⚠️ CONTEXTO: `SITE.noindexAll = true` → todo el sitio emite noindex,nofollow.
// Este enlazado no mueve nada en Google hasta que se quite el gate. Se construye
// ahora para que ya esté bien cuando se quite, no porque esté surtiendo efecto.
//
// DATA-DRIVEN CON GUARDA: los slugs NO se escriben a mano en un array de hrefs.
// Se declaran aquí, se resuelven contra la colección y, si uno no existe, el
// BUILD ROMPE. Mismo criterio que la guarda de SectionHeading: un enlace roto
// debe verse en build, no en producción. Si renombras un .mdx, esto te lo dice.
const GUIAS_MENU: { slug: string; label: string; sub: string }[] = [
  { slug: "como-medir-ventana-mosquitero", label: "Cómo medir", sub: "Toma bien las medidas de tu vano" },
  { slug: "tipos-de-mosquitero-cual-elegir", label: "Qué tipo elegir", sub: "Cuál va con tu ventana" },
  { slug: "tipos-de-malla-mosquitero", label: "Tipos de malla", sub: "Cuál aguanta tu caso" },
  { slug: "de-que-depende-el-precio-de-un-mosquitero", label: "De qué depende el precio", sub: "Qué mueve el costo por pieza" },
];

const articulosPublicados = await getCollection("articulos", ({ data }) => data.draft !== true);
const slugsPublicados = new Set(articulosPublicados.map((p) => p.id));

// La guarda: mismo filtro `draft !== true` que usa blog/[slug].astro para generar
// rutas. Así no basta con que el archivo exista — si está en draft no tiene ruta,
// y enlazarlo sería un 404 igual.
const guiasRotas = GUIAS_MENU.filter((g) => !slugsPublicados.has(g.slug));
if (guiasRotas.length > 0) {
  throw new Error(
    `[index.astro] El menú de guías apunta a artículos que no generan ruta: ` +
      `${guiasRotas.map((g) => g.slug).join(", ")}.\n` +
      `Causa probable: el .mdx se renombró, se borró, o tiene draft: true.\n` +
      `Publicados ahora mismo: ${[...slugsPublicados].sort().join(", ")}.\n` +
      `Arregla el slug en GUIAS_MENU o publica el artículo — no enlaces a un 404.`,
  );
}

const menuGuias = GUIAS_MENU.map((g) => ({ label: g.label, href: `/blog/${g.slug}`, sub: g.sub }));
// El botón destacado NO es de WhatsApp, a propósito: el CTA final de WhatsApp se
// quitó de esta página (ver más abajo) porque la home ya pide la conversión en el
// formulario y en el WhatsAppFloat. Reponerlo aquí sería devolverlo por la puerta
// de atrás. Lleva a /blog — que es otro enlace interno real, que es el punto.
// El conteo sale de la colección: si publicas un artículo, el número se corrige
// solo (por eso `icon: "arrow"`, ver MenuCta en SectionMenu.astro).
const menuGuiasCta = {
  label: "Ver todas las guías",
  href: "/blog",
  sub: `${articulosPublicados.length} artículos`,
  icon: "arrow" as const,
};

// ── Cómo se pide un mosquitero (proceso) ─────────────────────────────────────
// TODO: confirmar el proceso REAL del cliente (¿mide él?, ¿cobra la visita?,
// ¿cuánto tarda la entrega?). No prometer tiempos sin dato verificado.
//
// ⚠️ TODO CRÍTICO — 8 pasos, de los cuales 5 venían del scaffold original y 3 los
// añadí el 2026-07-14 a petición de Frank para llenar dos filas de 4 tarjetas:
// «Tipo de mosquitero» (3), «Malla» (4) y «Revisión y cuidado» (8). Son un
// DESGLOSE de lo que ya hacía el flujo de 5 (la asesoría de tipo/malla estaba
// embutida en Cotización; la revisión, en Instalación) — NO son servicios nuevos
// inventados. Aun así: nadie del negocio confirmó que el flujo real tenga estos
// cortes. Si el cliente dice que asesora y cotiza en el mismo mensaje, esto
// vuelve a 5 pasos o a 6, y la retícula lo aguanta (ver .pasos en <style>).
// El motivo de los 8 es de diseño, no de negocio. Ver docs/PROCEDENCIA.md §5.
//
// Cada paso declara su propia imagen y su alt: el alt vive AQUÍ, no en el SVG,
// para que al sustituir el placeholder por la foto real (public/images/proceso/
// paso-N.*) no se pierda la descripción. Mantener el 4:3 del placeholder.
const proceso: { paso: string; titulo: string; detalle: string; img: string; alt: string }[] = [
  { paso: "1", titulo: "Nos escribes", detalle: "Mándanos por WhatsApp el tipo de ventana o puerta y, si las tienes, las medidas.", img: "/images/proceso/paso-1.svg", alt: "Cliente enviando las medidas de su ventana por WhatsApp" },
  { paso: "2", titulo: "Medición", detalle: "Te decimos cómo medir o agendamos una visita para tomar las medidas exactas.", img: "/images/proceso/paso-2.svg", alt: "Flexómetro midiendo el ancho del vano de una ventana" },
  { paso: "3", titulo: "Tipo de mosquitero", detalle: "Según cómo abre tu ventana y el uso que le das, te decimos qué tipo le queda: corredizo, enrollable, abatible o plisado.", img: "/images/proceso/paso-3.svg", alt: "Comparación de tipos de mosquitero según la apertura de la ventana" },
  { paso: "4", titulo: "Malla", detalle: "Elegimos la malla con el mismo criterio: si hay mascotas, si pega el sol, si necesitas ver hacia afuera o frenar insectos más chicos.", img: "/images/proceso/paso-4.svg", alt: "Muestras de distintos tipos de malla para mosquitero" },
  { paso: "5", titulo: "Cotización", detalle: "Recibes el precio por pieza, ya con el tipo y la malla que quedamos.", img: "/images/proceso/paso-5.svg", alt: "Cotización por pieza con el tipo de mosquitero y la malla acordados" },
  { paso: "6", titulo: "Fabricación", detalle: "Armamos cada mosquitero a la medida de tu vano.", img: "/images/proceso/paso-6.svg", alt: "Armado del marco de aluminio del mosquitero en el taller" },
  { paso: "7", titulo: "Instalación", detalle: "Lo colocamos en tu ventana o puerta, ajustado al vano.", img: "/images/proceso/paso-7.svg", alt: "Instalación del mosquitero en la ventana" },
  { paso: "8", titulo: "Revisión y cuidado", detalle: "Verificamos que cierre y corra bien antes de irnos, y te decimos cómo limpiarlo para que dure.", img: "/images/proceso/paso-8.svg", alt: "Prueba de que la corredera del mosquitero cierre y corra bien" },
];

// ── FAQ — preguntas reales de compra ─────────────────────────────────────────
// TODO: validar cada respuesta con el cliente. Sin garantías ni plazos inventados.
//
// CRITERIO DE REDACCIÓN (por qué están escritas así y no en tres líneas):
//   • Responden con el CRITERIO, no solo con el dato: no basta "mide el vano",
//     hay que decir por qué se toma la medida MENOR — ahí está el oficio, y es
//     lo que separa a un proveedor de un catálogo.
//   • Cada respuesta cierra devolviendo la pelota (mándanos, cuéntanos): la
//     columna de al lado es el formulario, y la respuesta debe empujar a él.
//   • Cero cifras, plazos ni garantías sin dato verificado. Donde el negocio aún
//     no confirmó la política, la respuesta dice "te lo confirmamos al cotizar"
//     — que es verdad — en vez de inventar un número que luego no se sostenga.
//   • El <strong> marca el dato accionable, no el énfasis emocional.
//
// El JSON-LD FAQPage se alimenta de este array (lib/seo.ts) y ahí el HTML se
// limpia: por eso las respuestas deben leerse bien también SIN las negritas.
const faqs: { question: string; answer: string }[] = [
  {
    question: "¿Cómo mido el vano de mi ventana para pedir un mosquitero?",
    answer:
      "Con un flexómetro metálico, mide por dentro del marco: el <strong>ancho</strong> en tres alturas (arriba, en medio y abajo) y el <strong>alto</strong> en tres puntos (izquierda, centro y derecha). De cada terna, quédate con la <strong>medida menor</strong>. Los vanos casi nunca son perfectamente rectangulares, y una pieza fabricada sobre la medida mayor simplemente no entra. Anota los números en centímetros y mándanoslos con una foto de la ventana completa: con eso confirmamos el tipo y te decimos si el vano necesita algún ajuste antes de fabricar.",
  },
  {
    question: "¿Qué tipo de mosquitero me conviene?",
    answer:
      "Lo define el marco que ya tienes y el uso que le das, no el gusto. Los <strong>corredizos</strong> van con ventanas corredizas; los <strong>abatibles</strong>, con puertas de acceso diario; los <strong>enrollables</strong>, cuando quieres que la malla desaparezca al no usarla; los <strong>plisados</strong>, en vanos amplios y puertas de cristal; los <strong>fijos</strong>, en ventanas que no se abren. Si tu caso no encaja claro en ninguno, mándanos una foto de la ventana abierta: con verla sabemos cuál corresponde y te evitamos pagar la pieza equivocada.",
  },
  {
    question: "¿Hacen mosquiteros a medida o venden medidas estándar?",
    answer:
      "Solo <strong>a medida</strong>. Cada pieza se fabrica con las dimensiones exactas de tu vano; no cortamos sobre medidas de línea ni adaptamos un marco genérico. Es la única forma de que el mosquitero cierre completo, sin las holguras por donde se cuela justo lo que querías dejar afuera.",
  },
  {
    question: "¿Pueden cambiar la malla de un mosquitero que ya tengo?",
    answer:
      "Sí. Si el marco y los herrajes están sanos, se cambia <strong>solo la tela</strong> y la pieza queda funcional otra vez por una fracción de lo que cuesta reponerla. Si el perfil está vencido o torcido, o el herraje ya no sujeta, te lo decimos con franqueza y te damos las dos cifras —reparar y reponer— para que decidas tú con los números enfrente.",
  },
  {
    question: "¿De qué depende el precio de un mosquitero?",
    answer:
      "De tres cosas: las <strong>medidas</strong> del vano, el <strong>tipo</strong> de mosquitero y la <strong>malla</strong> que lleve. Por eso no publicamos lista de precios: una cifra genérica no aplicaría a tu ventana y solo serviría para que la comparación salga mal. Mándanos las medidas y te pasamos el precio <strong>por pieza</strong>, con el tipo y la malla que recomendamos para tu caso.",
  },
  {
    question: "¿Qué malla conviene en mi caso?",
    // TODO: confirmar con el cliente el catálogo REAL de mallas (nombres y
    // disponibilidad) antes de publicar. La respuesta describe criterios de
    // selección, no productos concretos, justo para no comprometer stock.
    answer:
      "Depende de lo que tengas que resolver, no del precio por metro. Hay tela estándar para insecto común, tejidos <strong>reforzados</strong> donde hay perros o gatos que se recargan, y tramas más cerradas para insecto pequeño. Cuéntanos si hay mascotas, si la ventana da a jardín o a la calle y qué tanto te importa conservar la vista: con eso te decimos qué tela pedir y por qué.",
  },
  {
    question: "¿Hacen medición a domicilio?",
    // TODO: confirmar si la visita tiene costo, si se acredita a la compra y en
    // qué zonas aplica. Hasta entonces la respuesta NO promete gratuidad.
    answer:
      "Sí, sobre todo cuando el vano es complicado o son <strong>varias piezas</strong> y un error de medición se multiplica. Escríbenos con tu zona y te confirmamos disponibilidad y condiciones de la visita antes de agendar nada. Si tu caso es simple, te ahorramos el paso: te decimos cómo medir y listo.",
  },
  {
    question: "¿Cuánto tardan en entregar e instalar?",
    // TODO: el cliente debe dar el plazo REAL por tipo de pieza. Prohibido poner
    // un número aquí hasta tenerlo verificado (regla: cero contenido fabricado).
    answer:
      "El plazo depende del tipo de pieza y de cuántas sean. Te lo confirmamos <strong>al cotizar</strong>, junto con el precio y por escrito: preferimos darte una fecha que podamos sostener a una cifra bonita que se caiga a la semana.",
  },
];
---

{/* schemaData.faqs → el JSON-LD FAQPage lo emite buildSchema() UNA sola vez
    (lib/seo.ts). Por eso <FAQAccordion> NO lleva `emitSchema` (anti-patrón B3:
    doble FAQPage). */}
<PageLayout keywords={KEYWORDS} pageType="home" schemaData={{ faqs }}>
  {/* ═══ 1) HERO — H1 único con la propuesta + kw1. TODO: validar copy con el cliente. ═══ */}
  <Hero
    title="Mosquiteros a medida para tus ventanas y"
    accent="puertas"
    subtitle="Los fabricamos e instalamos a la medida exacta de tu vano. Mándanos tus medidas por WhatsApp y te cotizamos por pieza."
    descRight={[
      "Cada ventana es distinta. Por eso no vendemos medidas de línea: tomamos el ancho y el alto de tu vano y armamos el mosquitero para que cierre completo, sin huecos por donde se cuele un mosquito. Trabajamos enrollables, corredizos, abatibles, plisados, magnéticos y fijos — te decimos cuál corresponde a tu tipo de ventana y para qué uso.",
      "Si ya tienes mosquiteros y solo se rompió la malla, también los reparamos: cambio de tela, marcos y herrajes. Escríbenos con una foto y las medidas, y te decimos qué conviene más en tu caso.",
    ]}
  />

  {/* ═══ MENÚ DE SECCIONES — barra full-width bajo el hero (data-driven desde NAV) ═══ */}
  <SectionMenu items={menuSecciones} cta={menuCta} />

  {/* ═══ 2) TIPOS DE MOSQUITERO — vitrina de categorías (data-driven desde SHOWCASE_HOME: los 4 principales) ═══ */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        eyebrow="Catálogo"
        title="Tipos de mosquitero"
        body={[
          "No todos los mosquiteros sirven para todas las ventanas. El tipo correcto lo define el marco que ya tienes y el uso que le das: no es lo mismo una ventana que abres dos veces al día que la puerta por la que entra y sale toda la familia.",
          "Abajo está cada tipo con el caso que resuelve. Si tu ventana no encaja claro en ninguno, mándanos una foto por WhatsApp: con verla sabemos cuál corresponde y te evitamos comprar la pieza equivocada.",
        ]}
      />
      <div class="showcase">
        {SHOWCASE_HOME.map((cat, i) => (
          <CategoryCard
            label={cat.label}
            href={cat.href}
            image={cat.image}
            imageAlt={cat.imageAlt}
            badge={cat.badge}
            blurb={cat.blurb}
            subcategories={cat.subcategories}
            ctaLabel={cat.ctaLabel}
            index={i}
          />
        ))}
      </div>

      {/* ── CADA TIPO, A FONDO ──────────────────────────────────────────────
          La vitrina de arriba entrega el catálogo de un vistazo, pero cada
          tarjeta solo cabe una frase. Estos bloques amplían sin obligar a
          entrar a otra página: cómo funciona cada tipo y qué caso resuelve.

          Data-driven: se recorre SHOWCASE_HOME y se filtra por AFONDO[slug]. Una
          categoría sin entrada en AFONDO simplemente no pinta bloque — así
          agregar categorías al catálogo nunca rompe esta sección.

          Regla canónica: TODOS idénticos —info a la IZQUIERDA, galería a la
          DERECHA (1 grande + 2 chicas debajo)—, sin alternar lados ni fondos.
          La galería no es opcional en el diseño: es la mitad del módulo.
          Las fotos aún son placeholders que declaran qué toma va en cada hueco;
          se sustituyen en AFONDO (site.ts) sin tocar este archivo.

          as="h3" NO es opcional: estos bloques cuelgan de la sección cuyo H2 es
          "Tipos de mosquitero". Con el H2 por defecto del componente salían
          cuatro H2 anidados bajo otro H2 —y encima detrás de los H3 de las
          tarjetas—, o sea un salto de jerarquía hacia arriba. La regla es
          H2 sección padre → H3 sub-bloque. */}
      <div class="afondo">
        {SHOWCASE_HOME.filter((cat) => AFONDO[cat.slug]).map((cat) => (
          <CategoryDetail
            id={`afondo-${cat.slug}`}
            as="h3"
            eyebrow="El tipo a fondo"
            title={cat.label}
            body={AFONDO[cat.slug].body}
            points={AFONDO[cat.slug].points}
            gallery={AFONDO[cat.slug].gallery}
            cta={{ label: cat.ctaLabel ?? `Ver ${cat.label}`, href: cat.href }}
          />
        ))}
      </div>
    </div>
  </section>

  {/* ═══ 3) SERVICIOS — data-driven desde TAXONOMY.services ═══ */}
  <section class="section">
    <div class="container">
      <SectionHeading
        eyebrow="Servicios"
        title="Qué hacemos"
        body={[
          "Cubrimos el mosquitero completo, de la medida a la instalación: lo fabricamos a las dimensiones exactas de tu vano, lo colocamos y verificamos que cierre y corra bien antes de irnos.",
          "Si ya tienes mosquiteros, no siempre hay que reponerlos. Cuando el marco aguanta, se cambia solo la malla; cuando no, te decimos con franqueza qué conviene más — reparar o reponer la pieza.",
        ]}
      />
      <div class="servicios">
        {SERVICES.map((s) => (
          <article class="servicio">
            <div class="servicio__contenido">
              <h3 class="servicio__titulo">{s.label}</h3>
              <p class="servicio__desc">{s.desc}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  {/* ═══ 4) PROCESO — cómo se pide un mosquitero ═══ */}
  <section class="section section--surface">
    <div class="container">
      <SectionHeading
        eyebrow="Proceso"
        title="Cómo pedir tu mosquitero"
        body={[
          "Pedir un mosquitero a medida es más simple de lo que parece: empieza con un mensaje y unas medidas. No necesitas saber qué tipo es el tuyo ni cómo se llama la malla — para eso estamos.",
          "Estos son los ocho pasos, del primer mensaje a la pieza instalada, para que sepas qué sigue en cada momento y qué necesitamos de ti en cada uno.",
        ]}
      />
      <ol class="pasos">
        {proceso.map((e, i) => (
          <li class="paso">
            <div class="paso__media">
              <img
                src={e.img}
                alt={e.alt}
                width="800"
                height="600"
                loading={i === 0 ? "eager" : "lazy"}
                decoding="async"
                class="paso__img"
              />
              <span class="paso__velo" aria-hidden="true"></span>
              <span class="paso__num" aria-hidden="true">{e.paso}</span>
            </div>
            <div class="paso__body">
              <h3 class="paso__titulo">{e.titulo}</h3>
              <p class="paso__detalle">{e.detalle}</p>
            </div>
          </li>
        ))}
      </ol>
    </div>
  </section>

  {/* ═══ 5) FAQ + COTIZACIÓN — dos columnas ═══════════════════════════════════
       Las dudas y el formulario van en el MISMO bloque a propósito: resolver la
       duda y no tener dónde actuar es perder el lead; poner el formulario antes
       de resolverla es pedirle datos a alguien que todavía no sabe qué pedir.
       Juntos, cada respuesta desemboca en la columna de acción, que en
       escritorio queda pegada (sticky) mientras se recorre el acordeón.

       ESTRUCTURA — una sola <section>, un solo <div class="container">:
         SectionHeading  → el H2 del bloque (contrato de 2 columnas del sitio).
         FAQAccordion    → title="" para NO pintar un segundo H2; su
                           aria-labelledby apunta a #faq-heading, que es ese H2.
                           flush → hereda ancho y padding del .container (antes
                           el acordeón traía su propio ancho de 820px y su
                           propio padding de sección: dos anchos distintos en la
                           misma página y un hueco muerto entre encabezado y
                           preguntas).
         slot="aside"    → QuoteForm. El acordeón no sabe qué es: solo lo coloca.

       El JSON-LD FAQPage lo emite buildSchema() desde `faqs` (schemaData arriba),
       NO este componente — sin `emitSchema` no hay doble FAQPage (anti-patrón B3).
       ══════════════════════════════════════════════════════════════════════ */}
  <section class="section section--faq">
    <div class="container">
      <SectionHeading
        id="faq-heading"
        eyebrow="Dudas"
        title="Preguntas frecuentes"
        body={[
          "Estas son las preguntas que más nos llegan por WhatsApp antes de cotizar: cómo medir el vano, qué tipo de mosquitero corresponde a cada ventana, de qué depende el precio y cuándo conviene reparar en vez de reponer.",
          "Si la tuya no está aquí, mándanos tu caso en el formulario de cotización: llena lo que sepas —aunque no tengas las medidas todavía— y te contestamos con el precio por pieza. Preferimos resolver la duda antes de fabricar que después de instalar.",
